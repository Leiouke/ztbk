<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core"%>
<!DOCTYPE html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8">
	    <meta http-equiv="X-UA-Compatible" content="IE=edge">
	    <meta name="viewport" content="width=device-width, initial-scale=1">
	    <!-- 上述3个meta标签*必须*放在最前面，任何其他内容都*必须*跟随其后！ -->  
	    <jsp:include page="../../include/h_superHead.jsp"></jsp:include>
	    <!-- Bootstrap table -->
	    <link href="${context}/css/plugins/bootstrap-table/bootstrap-table.min.css" rel="stylesheet">
	    <link rel="stylesheet" type="text/css" href="${context}/css/plugins/webuploader/webuploader.css">
	    <link href="${context}/css/plugins/bootstrap-table/bootstrap-editable.css" rel="stylesheet">
	    <link href="${context}/css/boocup_style.css" rel="stylesheet">
	    <style type="text/css">
	    	/*table里面的文本框css*/
		    .ibox-content-table input[type='text']{
		    	width:70px;
		        text-align: right;
		    }
		    input[readonly] {
			  background-color: #e9ecef;  /* 灰色背景 */
			  color: #6c757d;            /* 灰色文字 */
			  border-color: #ced4da;      /* 灰色边框 */
			  cursor: not-allowed;        /* 禁止光标样式 */
			  opacity: 1;                 /* 防止默认透明度变化 */
			}
	    </style>
	</head>
	<body>
		<div class="sonpage-body">
			<div class="col-md-12">
			   <div class="ibox float-e-margins">
		            <div class="ibox-content search-content">
			            <form id="form" class="form-inline">
			            <div class="col-xs-12">
			            	<div class="row">
			            		<div class="form-group inline-small">
			            			<label >订单编号：</label>
 				        			<input type="text" name="zd_id" readonly>
								</div>
								<div class="form-group inline-small">
			            			<label >录单员：</label>
 				        			<input type="text" name="o_id_input_name" disabled>
								</div>
								<div class="form-group inline-small">
			            			<label >传真：</label>
 				        			<input type="text" name="c_fax" id = "c_fax" disabled>
								</div>
								<div class="form-group inline-small">
								    <label >录单时间：</label>
								    <input name="input_date" id="input_date" type="text" class="form-control search-items layer-date" disabled>
								</div>
			            	</div>
				            <div class="row">
				            	   <div class="form-group inline-small not-null">
								    <label >类别：</label>
								    <select name="receipts_class" class="form-control dictionary search-items" disabled>
								    	<option></option>
								    </select>
								  </div>
								  <div class="form-group inline-small">
			            			<label >业务员：</label>
 				        			<input type="text" name="o_id_operatorname" id = "o_id_operatorname" disabled>
								  </div>
								  <div class="form-group inline-small">
			            			<label >邮政编码：</label>
 				        			<input type="text" name="c_zip" id = "c_zip" disabled>
								  </div>
							</div>
							<div class="row">
								<div class="form-group input-group inline-middle not-null" style = "margin-left:0px">
								    <label >客户编号：</label>
								    <input type="text" name="c_id" id = "c_id" class="form-control search-items auto-not-null" >
								    <div class="input-group-btn">
	                                    <button type="button" class="btn btn-white dropdown-toggle" data-toggle="dropdown">
	                                        <span class="caret"></span>
	                                    </button>
	                                    <ul class="dropdown-menu dropdown-menu-right" role="menu"></ul>
	                                </div>
								  </div>
								  <div class="form-group inline-large">
								    <label >户号(_客户名称)：</label>
								    <input type="text" name="c_department" id = "c_department" class="form-control search-items" disabled>
								  </div>
							</div>
							<div class="row">
								<div class="form-group inline-small not-null">
								    <label >订单标识：</label>
								    <select name="kind_id" class="form-control dictionary search-items" >
								    	<option></option>
								    </select>
								</div>
								<div class="form-group inline-small">
			            			<label >联系人：</label>
 				        			<input type="text" name="c_contact_man" id = "c_contact_man" disabled>
								</div>
								<div class="form-group inline-small">
			            			<label >电话：</label>
 				        			<input type="text" name="c_tel" id = "c_tel" disabled>
								</div>
								<div class="form-group inline-small not-null">
								    <label >推广类型：</label>
								    <select name="mark_id" class="form-control dictionary search-items" >
								    	<option></option>
								    </select>
								</div>
							</div>
							<div class="row">
								<div class="form-group inline-small not-null">
								    <label >销售方式：</label>
								    <select name="sale_style_id" class="form-control dictionary search-items" >
								    	<option></option>
								    </select>
								</div>
								<div class="form-group inline-small not-null">
								    <label >订单属性：</label>
								    <select name="zd_attribute" class="form-control dictionary search-items" >
								    	<option></option>
								    </select>
								</div>
								<div class="form-group inline-small not-null">
								    <label >结算方式：</label>
								    <select name="js_attribute" class="form-control dictionary search-items" >
								    	<option></option>
								    </select>
								</div>
								<div class="form-group inline-small not-null">
								    <label >配送类型：</label>
								    <select name="collect_style" id = "collect_style" class="form-control dictionary search-items" >
								    	<option></option>
								    </select>
								</div>
							</div>
							<div class="row">
								<div class="form-group inline-large">
			            			<label >通讯地址：</label>
 				        			<input type="text" name="c_address" id = "c_address" disabled>
								</div>
								<div class="form-group inline-small">
			            			<label >收件人：</label>
 				        			<input type="text" name="accept_man" id = "accept_man" disabled>
								</div>
								<div class="form-group inline-small">
			            			<label >户号：</label>
 				        			<input type="text" name="custom_id" id = "custom_id" disabled>
								</div>
							</div>
							<div class="row">
								<div class="form-group inline-small">
			            			<label >ORDER：</label>
 				        			<input type="text" name="ORDER" id = "ORDER" disabled>
								</div>
								<div class="form-group inline-small">
			            			<label >TYO：</label>
 				        			<input type="text" name="TYO" id = "TYO" disabled>
								</div>
								<div class="form-group inline-large">
			            			<label >收货地址：</label>
 				        			<input type="text" name="c_address_song" id = "c_address_song" disabled>
								</div>
							</div>
							<div class="row">
								  <div class="form-group inline-small">
								    <label >总品种：</label>
								    <input type="text" name="total_count" class="form-control search-items" value="0.00" readonly>
								  </div>
								  <div class="form-group inline-small">
								    <label >总份数：</label>
								    <input type="text" name="total_amount" class="form-control search-items" value="0.00" readonly>
								  </div>
								  <div class="form-group inline-small">
								    <label >总金额：</label>
								    <input type="text" name="real_money" class="form-control search-items" value="0.00" readonly>
								  </div>
								  <input type="hidden" name="total_money" class="form-control search-items" value="0.00" readonly>
							</div>
							<div class="row">
								  <div class="form-group inline-large">
								    <label >备注：</label>
								    <input type="text" name="memo" class="form-control search-items">
								  </div>
								  <div class="form-group inline-large">
								    	<input type="text" name="zd_id" class="form-control search-items" style="display:none">
								  </div>
							</div>
						 </div>
						</form>
		            </div>
       		</div>
       		<div class="ibox float-e-margins">
	            <div class="ibox-title">
	                <h5>订单明细</h5>
	                <div class="ibox-tools">
	                    <a class="collapse-link">
	                        <i class="fa fa-chevron-up"></i>
	                    </a>
	                </div>
	            </div>
	            <div class="ibox-content ibox-content-table">
	                <div class="row row-lg">                    
	                    <div class="col-sm-12">
	                        <div class="btn-group hidden-xs" id="tableTool" role="group">
	                        	<button type="button" class="btn btn-outline btn-default" id="add">
	                            	<i class="glyphicon glyphicon-plus" aria-hidden="true"></i>
	                        	</button>
	                            <button type="button" class="btn btn-outline btn-default" id="delete_items">
	                               <i class="glyphicon glyphicon-trash" aria-hidden="true"></i>
	                           	</button>
	                            <button type="button" class="btn btn-outline btn-default" id="config">
	                               <i class="glyphicon glyphicon-cog" aria-hidden="true"></i>
	                            </button>
	                            <select class="form-control" >
	                           	   <option value="all">导出全部</option>
					               <option value="basic">导出当页</option>	
					            </select>
	                        </div>
	                        <table id="table" data-mobile-responsive="true">
	                            
	                        </table>
	                    </div>
	                </div>
	            </div>
        </div>       			
		</div>
	</div>
	<div class="sonpage-footer">
	    <button id="save" class="btn btn-primary" type="button">保存</button>
	    <button id="cancel" class="btn btn-white" type="button">取消</button>
	</div>
	</body>
	<!-- Bootstrap table -->
    <script src="${context}/js/plugins/bootstrap-table/bootstrap-table.min.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/locale/bootstrap-table-zh-CN.min.js"></script>
    <!-- Bootstrap table export-->
    <script src="${context}/js/plugins/bootstrap-table/export/bootstrap-table-export.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/tableExport.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/js-xlsx/xlsx.core.min.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/jsPDF/jspdf.min.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/jsPDF/jspdf.plugin.autotable.js"></script>
    <!-- Bootstrap table editable-->
    <script src="${context}/js/plugins/bootstrap-table/bootstrap-editable.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/bootstrap-table-editable.js"></script>
    
	<script src="${context}/js/plugins/layer/layer.min.js"></script>
	<!-- plugins -->
 	<script src="${context}/js/plugins/suggest/bootstrap-suggest-new.min.js"></script>
	<!-- layerDate plugin javascript -->
    <script src="${context}/js/plugins/layer/laydate-new/laydate.js"></script>
	<script type="text/javascript">
	function queryParams(param) {
		var json_obj_invoice = {};
		json_obj_invoice['limit'] =param.limit;
		json_obj_invoice['offset'] =param.offset;
		json_obj_invoice['sortName'] =this.sortName;
		json_obj_invoice['sortOrder'] =this.sortOrder;
	    return json_obj_invoice;
	}
	
	$('#zd_id').val('${zd_id}');
	
	var qk_zd = JSON.parse('${oneJson}');
	
	function load_table_data_success(data){
		if (data.success){
   			layer.msg("操作成功！");
   			load_sum_list("${context}/csu/getTableCollectDataBK",{'queryId':'${queryId}','guidname':'qkZd_guid'},$table);
    	} else {
    		layer.msg(data.errorMsg);
    	}
	}
	
	var $table = $('#table');
	load_sum_list_first("${context}/csu/getTableCollectDataBK",{'queryId':'${queryId}','guidname':'qkZd_guid'});
	$(document).ready(function () {
		
		$(".layer-date").each(function(){
			inistal_one_data('#'+$(this).attr('id'));
		});
		
		//增加条目layer
		var $add=$("#add");
		$add.on('click', function () {
			if($("#c_department").val()==""||$("#kind_id").val()==""||$("#mark_id").val()==""||$("#sale_style_id").val()==""||$("#js_attribute").val()==""){
				alert("请先输入客户，订单标识，销售方式，推广类型和结算方式");
			}else{
				var c_department = $("#c_department").val();
				var c_id = $("#c_id").val();
				var kind_id = $("#kind_id").val();
				var mark_id = $("#mark_id").val();
				var sale_style_id = $("#sale_style_id").val();
				var zd_attribute = $("#zd_attribute").val();
				var js_attribute = $("#js_attribute").val();
				var index=layer.open({
		              type: 2,
		              title:"新增收订明细",
		              maxmin: true,
		              area: ['620px', '580px'],
		              scrollbar: true,
		              moveOut:true,
		              skin: 'layui-layer-rim', //加上边框
		              content: 'qkZdItemTempAdd?c_id='+c_id+'&c_department='+c_department+'&kind_id='+kind_id+'&mark_id='+mark_id
		            		    +'&sale_style_id='+sale_style_id+'&zd_attribute='+zd_attribute+'&js_attribute='+js_attribute,
		              end:function () {
		            	  $table.bootstrapTable('refresh');
		              }
		          });
				  if(true){
					  layer.full(index);
				  }
			}
		 });
		
		$('#save').on('click', function () {
			
			if(!has_null($("#form"))){
				if($("input[name='c_id']").attr("data-id")=="") {
					layer.msg("客户编号不正确");
				} else {
					ajax_function("editQkZd","post",$('#form').serialize(),'保存成功');
				}
			}
			
		});
		
		$('#delete_items').on('click',function(){
			var inc_nos = $.map($table.bootstrapTable('getSelections'), function (row) {
                return row.inc_no;
            });
			if(inc_nos.length!=0) {
				ajax_function_ask_and_dosuccess("确认删除？","deleteQkZdItemTempList","post",{'inc_nos':inc_nos},load_table_data_success);
			} else {
				layer.msg("未选择明细！");
			}
		});
		
		
		if(qk_zd.is_verify==1){//提交了隐藏保存按钮
			$('#save').hide();
		}
		
		//加载字典数据
		get_dictionary("${context}", qk_zd);
		
		//填写已有数据
		set_one_info($("#form"), qk_zd);
		//bootstrap初始化		
		initialize_table($table,"getQkZdItemTempList",${tableHeader},queryParams,"#tableTool",550);
 		
		$table.bootstrapTable('refreshOptions',{onLoadSuccess: function(data){
			var sum_money=0;
 			var sum_count=0;
 			var sum_amount=0;
 			var sum_total_money = 0;
 			$.each(data.rows, function(index, row){
				if(row.real_money==undefined){
					sum_money+=0;
				}else{
					sum_money+=row.real_money;
				}
				
				if(row.h_amount==undefined){
					sum_amount+=0;
				}else{
					sum_amount+=row.h_amount;
				}
				
				sum_count+=1;
				
				if(row.total_money==undefined){
					sum_total_money+=0;
				}else{
					sum_total_money+=row.total_money;
				}
			});
 			sum_money=sum_money.toFixed(2);
 			$("input[name='real_money']").val(sum_money);
 			$("input[name='total_count']").val(sum_count);
 			$("input[name='total_amount']").val(sum_amount);
 			$("input[name='total_money']").val(sum_total_money);
		}});
		
		//表格配置 layer
		var $config=$("#config");
		
		table_column_config_layer($config,2,'表格属性配置','${context}/csu/columnConfig?queryId=${queryId}');
		
		$('#tableTool').find('select').change(function () {
			 $('#table').bootstrapTable('refreshOptions',{exportDataType: $(this).val()});
	    });
		
		//自动搜索填补
		initialize_bsSuggest_bk_client("${context}", "c_department", "c_id");
		initialize_bsSuggest_fc_user("${context}", "o_id_receiver_name", "o_id_receiver");      // 放用户信息
		
		var c_id_first = $('#c_id').val();
		client_information_auto_input(c_id_first);
		
		function initialize_bsSuggest_bk_client(context, input_name, input_id){
			console.log(3333);
			initialize_bsSuggest($("input[name='"+input_id+"']"),context+"/bk/basic/getClientAutoSearch?keyword=","c_department","c_id",{c_id: "客户编号",c_department:"户号_客户名称"},["c_id","c_department"],false,bsSuggest_data_process_bk_client,null);
			$("input[name='"+input_id+"']")
		    .on('onSetSelectValue', function (e, keyword) {
		        $("input[name='"+input_name+"']").val(keyword['id']);
		        client_information_auto_input($('#c_id').val());
		  }).on('onUnsetSelectValue', function (e) {
			  $("input[name='"+input_name+"']").val('');
		  }).on('keyup',function(){
			  if($(this).val()==""){
				  $("input[name='"+input_name+"']").val('');
			  }
		  });
		}
		
		function client_information_auto_input(c_id){
			$.ajax({
		          type: "post",
		          contentType: "application/json",          // 明确指定请求体格式
		          url: "${context}/bk/basic/getClientList",
		          data: JSON.stringify({ c_id:$('#c_id').val()}),
		          dataType: 'JSON',
		          success: function (data) {
		          	if(data.total==0){
		          		alert("编号未搜索到商品，请检查编号");
		          	}else{
		          		console.log('tyo='+data.rows[0].c_address);
		          		//c_tax,c_charge_man,c_zip,c_contact_man,c_tel,c_address,accept_man,custom_id,c_address_song
		          		$('#c_fax').val(data.rows[0].f_tax);
		          		//$('#o_id_operatorname').val(data.rows[0].c_charge_man);
		          		$('#c_zip').val(data.rows[0].c_zip);
		          		$('#c_contact_man').val(data.rows[0].c_contact_man);
		          		$('#c_tel').val(data.rows[0].c_tel);
		          		$('#c_address').val(data.rows[0].c_address);
		          		$('#accept_man').val(data.rows[0].accept_man);
		          		$('#custom_id').val(data.rows[0].custom_id);
		          		$('#c_address_song').val(data.rows[0].c_address_song);
		          		$('#ORDER').val(data.rows[0].c_bak1);
		          		$('#TYO').val(data.rows[0].c_bak3);
		          		console.log('tyo='+data.rows[0].c_bak3);
		          	}
		          },
		          error: function (data) {
		          	console.log(data);
		          }
		      });	
		}
		
	});
	
	function toDel(inc_no){
		ajax_function_ask_and_dosuccess("确认删除？","deleteQkZdItemTempList","post",{'inc_nos':inc_no},load_table_data_success);
	}
	
	//编辑页面
	 function toEdit(inc_no){
		 open_layer_refresh(2,'编辑订单','qkZdItemEdit?inc_no='+inc_no,$table,['620px', '580px'],true);
	 }	
	
// 	 function toPeriod(qk_id){
// 		 open_layer_refresh(2,'商品商品刊期','qkZdItemPeriod?qk_id='+qk_id,$table,['620px', '580px'],true);
// 		}
	
	function renderOperator(value,row,index){
	   var str = "";
	   if(qk_zd.is_verify==1){//提交了隐藏保存按钮
			return str;
		}
// 	   str += "<a onclick=\"toPeriod('"+row.qk_id+ "')\">刊期</a>";
// 	   str += "&nbsp;&nbsp;";
	   str += "<a onclick=\"toEdit('" + row.inc_no + "')\">编辑</a>";
	   str += "&nbsp;&nbsp;";
	   str += "<a onclick=\"toDel('" + row.inc_no + "')\">删除</a>";
	   str += "&nbsp;&nbsp;";
		
		return str;
	}
	</script>
</html>