	/**
	 * 退回结算单
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/gobackStatement")
	@ResponseBody
    public Object gobackStatement(@RequestParam Map postData,HttpSession httpSession){
		User user = (User)httpSession.getAttribute("user");
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"statement_no","input_code"};
		// 加入sp的名称
		postData.put("spName", "u_np_statement_del");
		postData.put("input_code", user.getAccount());
				
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		paramNames = new String[]{"source_no", "sourece_type"};
		code = yhService.doCallSp(postData, paramNames, null);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 批量退回结算单
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/batchGobackStatement")
	@ResponseBody
    public Object batchGobackStatement(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession){
		Map<String,Object> bd_map=new HashMap<String, Object>();
		User user = (User)httpSession.getAttribute("user");
		if(postData!=null&&postData.size()>0){
			for(Map<String,Object> item_map: postData){		
				// 入参, 注意按照顺序
				String paramNames[] = new String[]{"statement_no","input_code"};
				// 加入sp的名称
				item_map.put("spName", "u_np_statement_del");
				item_map.put("input_code", user.getAccount());
						
				int code = baseService.doCallSp(item_map, paramNames, null);
				
				if (code != 0) {
					return this.getAjaxResult(code);
				}
				
				paramNames = new String[]{"source_no", "sourece_type"};
				code = yhService.doCallSp(item_map, paramNames, null);
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}
		return "{\"success\":true}";
    }
	
	/**
	 * 记账操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/accountStatement")
	@ResponseBody
    public Object accountStatement(@RequestParam Map postData,HttpServletRequest request,HttpSession httpSession){
		String[] statement_nos=request.getParameterValues("statement_nos");
		User user=(User)httpSession.getAttribute("user");
		postData.put("account_person", user.getAccount());
		if(statement_nos !=null && statement_nos.length>0){
			for(int i=0;i < statement_nos.length;i++){
				// 入参, 注意按照顺序
				String paramNames[] = {"statement_no","account_person","account_month"};
				// 加入sp的名称
				postData.put("spName", "u_finance_statement_account");
				
				postData.put("statement_no", statement_nos[i]);
						
				int code = baseService.doCallSp(postData, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}
		return "{\"success\":true}";
    }
	
	/**
	 * 撤销记账操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteStatementAccount")
	@ResponseBody
    public Object deleteStatementAccount(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request){		
		String[] statement_nos=request.getParameterValues("statement_nos");
		if(statement_nos !=null && statement_nos.length>0){
			for(int i=0; i < statement_nos.length;i++){
				// 入参, 注意按照顺序
				String paramNames[] = {"statement_no"};
				// 加入sp的名称
				postData.put("spName", "u_finance_statement_account_cancel");					
				
				postData.put("statement_no", statement_nos[i]);

				int code = baseService.doCallSp(postData, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}
		
		return "{\"success\":true}";
    }
	
	/**
     * 进入开票申请界面-未申请状态
     * 
     * @param postData
     * @param httpSession
     * @return
     * @throws JsonProcessingException
     */
	@RequestMapping(value="/toStatementClaimKp",method=RequestMethod.GET)
    public ModelAndView toStatementClaimKp(@RequestParam Map postData,HttpSession httpSession) throws JsonProcessingException {  // 注意这个postData里面已经包含了id的字段值
        ModelAndView mv = new ModelAndView();     
        
        Map<String, Object> bankDataList = this.getTableDataList(postData,5000008);
        List<Map> bankList = (List<Map>) bankDataList.get("rows");
        mv.addObject("bankList", bankList);

        if (postData.get("bank_id")==null && bankList.size() > 0) {
        	postData.put("bank_id", bankList.get(0).get("id"));
        }
        // 未申请开票的, 读取结算单含客户信息的发票
        // 单记录查询
		Map<String, Object> oneQuery = baseService.getOneQuery(5110014, postData);
		
		//oneQuery.put("kp_mail","notice@qiye.163.com");
        
        if (Float.parseFloat(oneQuery.get("claim_kp_money").toString()) == 0) {
			oneQuery.put("claim_kp_money", oneQuery.get("can_kp_money"));
		}
		
		mv.addObject("oneJson", JsonUtil.mapToString(oneQuery));
        mv.setViewName("np/statement/statementClaimKp");
		
        return mv;
    }
	
	/**
	 * 结算单申请开票
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/statementClaimKp")
	@ResponseBody
    public Object statementClaimKp(@RequestParam Map postData, HttpSession httpSession) {
		User user = (User)httpSession.getAttribute("user");
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"statement_no","kp_type","tax_rate","is_item","claim_kp_money", "o_id_input",
				"kp_content", "kp_amount", "kp_unit", "kp_memo", "bank_id","kp_mail"};
		String returnNames[] = new String[]{"kp_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_statement_claim_kp");
		postData.put("o_id_input", user.getAccount());
			
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		// 重算这次发票对应的结算单明细的已开票金额
		paramNames = new String[]{"kp_id", "is_to_edit"};
		postData.put("is_to_edit", 0);
		postData.put("spName", "u_finance_invoice_kp_statement_item_calculate");
		code = baseService.doCallSp(postData, paramNames, null);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 结算单撤销申请开票
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/statementCancelClaimKp")
	@ResponseBody
    public Object statementCancelClaimKp(@RequestParam Map postData, HttpSession httpSession){
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"statement_no"};
		String returnNames[] = new String[]{"kp_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_statement_cancel_claim_kp");
				
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		// 以下做发票作废操作
		// 入参, 注意按照顺序
		paramNames = new String[]{"kp_id","o_id_destroy"};
		// 加入sp的名称
		postData.put("spName", "u_finance_invoice_kp_delete");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_destroy", user.getAccount());
        
		code = baseService.doCallSp(postData, paramNames, null);		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");	
		paramNames = new String[]{"kp_id", "is_to_edit"};
		postData.put("is_to_edit", 0);
		postData.put("spName", "u_finance_invoice_kp_statement_item_calculate");
		code = baseService.doCallSp(postData, paramNames, null);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 批量申请开票操作
	 * 业务逻辑： 每个结算单必须要有开票银行信息才可以申请开票, 批量申请也包括批量提交
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/batchStatementClaimKp")
	@ResponseBody
    public Object batchStatementClaimKp(@RequestParam Map postData,HttpServletRequest request,HttpSession httpSession){
		String[] statement_nos = request.getParameterValues("statement_nos");
		User user = (User) httpSession.getAttribute("user");
		postData.put("o_id_input", user.getAccount());
		if(statement_nos !=null && statement_nos.length>0){
			for(int i=0;i < statement_nos.length;i++){
				postData.put("statement_no", statement_nos[i]);
				// 可以批量开票的条件有 1.客户必须有默认的银行信息 2.开到明细字段为否
				Map<String, Object> oneQuery = baseService.getOneQuery(5110009, postData);	
				
				// 查到1条记录是合适的
				if (oneQuery != null) {
					// 入参, 注意按照顺序
					String paramNames[] = new String[]{"statement_no","kp_type","tax_rate","is_item","claim_kp_money", "o_id_input",
							"kp_content", "kp_amount", "kp_unit", "kp_memo", "bank_id"};
					String returnNames[] = new String[]{"kp_id"};
					// 加入sp的名称
					postData.put("spName", "u_finance_statement_claim_kp");
					postData.put("kp_type", oneQuery.get("kp_type"));
					postData.put("tax_rate", oneQuery.get("tax_rate"));
					postData.put("is_item", oneQuery.get("is_item"));
					postData.put("claim_kp_money", oneQuery.get("claim_kp_money"));
					postData.put("kp_content", oneQuery.get("kp_content"));
					postData.put("kp_amount", oneQuery.get("kp_amount"));
					postData.put("kp_unit", oneQuery.get("kp_unit"));
					postData.put("bank_id", oneQuery.get("id"));
							
					int code = baseService.doCallSp(postData, paramNames, returnNames);
					
					if (code != 0) {
						System.out.println("不允许申请开票！");
						continue;
					}
					
					// 重算这次发票对应的结算单明细的已开票金额
					paramNames = new String[]{"kp_id", "is_to_edit"};
					postData.put("is_to_edit", 0);
					postData.put("spName", "u_finance_invoice_kp_statement_item_calculate");
					code = baseService.doCallSp(postData, paramNames, null);
					if (code != 0) {
						continue;
					}
					
					// 以下做销售开票单提交操作
					paramNames = new String[]{"statement_no", "kp_id"};
					// 加入sp的名称
					postData.put("spName", "u_finance_invoice_kp_claim_commit");
							
					code = baseService.doCallSp(postData, paramNames, null);
					
					if (code != 0) {
						continue;
					}
					
				}
			}
		}
		return "{\"success\":true}";
    }
	
