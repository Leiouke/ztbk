    }
	
	/**
	 * 引入结算单--可以是3种类型的
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/importStatementItem")
	@ResponseBody
	public Object importStatementItem(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession){
		//List<Map<String, Object>> item_list=(List<Map<String, Object>>) postData.get("item_ids_codes");
		User user = (User)httpSession.getAttribute("user");
//		Map<String,Object> bd_map = new HashMap<String, Object>();
		if(postData != null && postData.size()>0){
			for(Map<String,Object> item_map : postData){
				String paramNames[] = new String[]{"custom_s_id", "source_no", "sourece_type", "real_money", "total_money", 
						"input_code", "memo"};
				// 出参, 有顺序
				String returnNames[] = {"statement_no", "err_msg"};  // err_msg 没用的 实际 先放着吧
				// 加入sp的名称
				item_map.put("spName", "u_np_statement_new");
				item_map.put("input_code", user.getAccount());
						
				int code = baseService.doCallSp(item_map, paramNames, returnNames);
				if (code != 0) {
					AjaxResult result = this.getAjaxResult(code);
					// 假如是 刊号 和  财务分类没有关联上, 给出明确的来源单号提示
					if (code == 99999) {
						result.setErrorMsg(result.getErrorMsg() + " 来源单号：" + item_map.get("source_no"));
					}
					return result;
				}
				
				paramNames = new String[]{"source_no", "sourece_type"};
				code = yhService.doCallSp(item_map, paramNames, null);
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}		
		}				
		return "{\"success\":true}";
	}
	
