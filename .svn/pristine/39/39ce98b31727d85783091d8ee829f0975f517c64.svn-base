	/**
	 * 合并开票内容明细
	 * 逻辑：先新增合并后的明细, 然后删除待合并的明细
	 * 
	 * 
	 */
	@RequestMapping(value="/mergeSaleInvoiceContentItem")
	@ResponseBody
    public Object mergeSaleInvoiceContentItem(@RequestParam Map postData)throws JsonProcessingException{
		String[] ids = postData.get("ids").toString().split(",");
		// 先保存
		int code = this.addOneSaleInvoiceContentItem(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		for (String id : ids) {
			postData.put("id", id);
			code = this.deleteOneSaleInvoiceContentItem(postData);
			if (code != 0) {
				return this.getAjaxResult(code);
			}
		}

		return "{\"success\":true}";
    }
	
	/**
	 * 新增开票内容明细
