	<script type="text/javascript">
	
	function getFormDataIncludingDisabled() {
	    // 1. 查找当前所有处于禁用状态的元素
	    var $disabledInputs = $("#form").find(':disabled');
	    
	    // 2. 临时解禁
	    $disabledInputs.prop('disabled', false);
	    
	    // 3. 抓取 JSON 数据
	    var fullData = formToJson($("#form"));
	    
	    // 4. 立即恢复禁用
	    $disabledInputs.prop('disabled', true);
	    
	    return fullData;
	}
	
	function queryParams(param) {
		// 使用通用函数获取完整数据
	    var json_obj_invoice = getFormDataIncludingDisabled();
	    
	    // 补充分页和排序参数
	    json_obj_invoice['limit'] = param.limit;
	    json_obj_invoice['offset'] = param.offset;
	    json_obj_invoice['sortName'] = this.sortName;
	    json_obj_invoice['sortOrder'] = this.sortOrder;
	    
	    return json_obj_invoice;
	}
	
	function load_table_data_success(data){
		if (data.success){
   			layer.msg("操作成功！");
   			load_sum_list("${context}/csu/getTableCollectData",{'queryId':'${queryId}','guidname':'qkBdOut_guid'},$table);
    	} else {
    		layer.msg(data.errorMsg);
    	}
	}
	
	// 获取日期值并计算天数差
	function calculateDateDifference() {
	    // 获取开始日期和结束日期的值
	    var startDateStr = $('#start_time').val();
	    var endDateStr = $('#end_time').val();
	    
	    // 检查是否两个日期都已填写
	    if (!startDateStr || !endDateStr) {
	        console.log('请填写开始日期和结束日期');
	        return null;
	    }
	    
	    // 将字符串转换为Date对象
	    var startDate = new Date(startDateStr);
	    var endDate = new Date(endDateStr);
	    
	    // 计算天数差（结束日期 - 开始日期）
	    var timeDifference = endDate.getTime() - startDate.getTime();
	    var dayDifference = Math.floor(timeDifference / (1000 * 3600 * 24));
	    
	    return dayDifference;
	}
	
	var $table = $('#table');
	load_sum_list_first("${context}/csu/getTableCollectData",{'queryId':'${queryId}','guidname':'qkBdOut_guid'});
	$(document).ready(function () {
		// ================= 1. 封装获取并回填控制信息的公共函数 =================
	    function getAndFillBdControlInfo(startDateInit) {
	        // 优先从输入框取值，取不到则用后台传来的初始值
	        var f_id = $("input[name='f_id']").val() || '${f_id}';
	        var bd_regular = $('#qk_bd_regular').val() || '${qk_bd_regular}';

	        if (!f_id || !bd_regular || !startDateInit) {
	            return;
	        }

	        var reqData = {
	            f_id: f_id,
	            qk_bd_regular: bd_regular,
	            start_date_init: startDateInit
	        };

	        // 发起请求获取控制信息 [cite: 3]
	        ajax_function_dosuccess("${context}/bk/bd/getBdControlInfo", "post", reqData, function(data) {
	            if (data.success) {
	                // 回填开始日期和结束日期 
	                if (data.start_date) {
	                    $("input[name='start_time']").val(data.start_date);
	                }
	                if (data.end_date) {
	                    $("input[name='end_time']").val(data.end_date);
	                }

	                // 控制“是否重报” (Reset) 下拉框的状态
	                var $resetSelect = $("select[name='Reset']");
	                var canRebd = (data.rebd_enabled === true || data.rebd_enabled === 1 || data.rebd_enabled === '1' || data.rebd_enabled === 'true');

	                if (canRebd) {
	                    $resetSelect.prop("disabled", false);
	                } else {
	                    $resetSelect.prop("disabled", true);
	                    $resetSelect.val("0"); 
	                }
	            } else {
	                layer.msg(data.errorMsg || "获取报订日期配置失败！");
	            }
	        });
	    }
	    // ================= 2. 初始化日期控件 =================
	    // 排除 start_time，让其他带有 layer-date 类的元素走原有默认初始化
	    $(".layer-date").not("#start_time").each(function(){
	        inistal_one_data('#'+$(this).attr('id')); // [cite: 3]
	    });
	    
	    // 单独为 start_time 初始化，并加入 done 回调函数监听值的改变
	    laydate.render({
	        elem: '#start_time',
	        format: 'yyyy-MM-dd',
	        max: '2099-06-16',
	        calendar: true,
	        istime: false,
	        istoday: true,
	        zIndex: 99999999,
	        done: function(value, date, endDate) {
	            // 当用户在控件中选中了新日期后，value 就是选中的字符串 (例如 '2026-05-15')
	            if (value) {
	                getAndFillBdControlInfo(value);
	            }
	        }
	    });
	    // ================= 3. 基础页面数据渲染 =================
	    if('${f_id}' != ''){
	         $("input[name='f_id']").val('${f_id}'); // [cite: 1]
	    }
	    if('${f_department}' != ''){
	         var f_department= '${f_department}';
	         $("input[name='f_department']").val(f_department); // [cite: 1]
	    }

	    // 填入报订周期并触发首次加载
	    if('${qk_bd_regular}' != ''){
	         var qk_bd_regular= '${qk_bd_regular}'; // [cite: 1]
	         setTimeout(function(){
	             $('#qk_bd_regular').val(qk_bd_regular); // [cite: 1]
	             
	             // 页面初次加载时，根据表头带来的 bd_start_date 触发一次运算回填
	             if ('${bd_start_date}') {
	                 getAndFillBdControlInfo('${bd_start_date}'); // [cite: 1]
	             }
	         }, 1000); // 延迟等待字典等数据渲染完成
	    }
	    
		//$(".layer-date").each(function(){
			//inistal_one_data('#'+$(this).attr('id'));
		//});
		
		$('#save').on('click', function () {
			const qk_bd_regular = $("select[name='qk_bd_regular']").val();
		    const dayDifference = calculateDateDifference();

		    // 逻辑校验
		    if (qk_bd_regular == "01" && dayDifference < 30){
		        alert("按月报订但是时间段小于30天，无法报订！");
		        return; // 拦截
		    } else if (qk_bd_regular == "02" && dayDifference < 15){
		        alert("半月报订但是时间段小于15天，无法报订！");
		        return; // 拦截
		    } else if (qk_bd_regular == "03" && dayDifference < 7){
		        alert("按周报订但是时间段小于7天，无法报订！");
		        return; // 拦截
		    }

		    // 校验必填项
		    if(!has_null($("#form"))){
		        // --- 核心修改部分 ---
		        var $disabledInputs = $('#form').find(':disabled');
		        $disabledInputs.prop('disabled', false); // 1. 临时解禁

		        var formData = $('#form').serialize();   // 2. 序列化（此时包含禁用字段）

		        $disabledInputs.prop('disabled', true);  // 3. 恢复禁用
		        // ---------------------

		        ajax_function("addQkBd", "post", formData, '保存成功');
		    }
			
		});
		
		//加载字典数据
		get_dictionary("${context}", null);

		//bootstrap初始化（不加载数据）		
		initialize_table($table,"",${tableHeader},queryParams,"#tableTool",550);
		
		//查询
		$("#search").on('click',function(){
			if (!has_null($("#form"))) {
		        // 1. 获取包含 disabled 字段的完整数据
		        var json_data_list = getFormDataIncludingDisabled();
		        
		        // 2. 补充业务参数
		        json_data_list['queryId'] = '${queryId}';
		        
		        // 3. 调用你的汇总搜索函数
		        // 此时 json_data_list 是一个完整的 JS 对象
		        search_sum_list("${context}/csu/getTableCollectData", json_data_list, "getQkFactoryCanBdList", $table);
		    }
		});
 		
