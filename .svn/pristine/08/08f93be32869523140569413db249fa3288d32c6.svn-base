	<!-- layerDate plugin javascript -->
    <!-- <script src="${context}/js/plugins/layer/laydate/laydate.js"></script>--> 
    <script src="${context}/js/plugins/layer/laydate-new/laydate.js"></script>
    <!-- plugins -->
 	<script src="${context}/js/plugins/suggest/bootstrap-suggest-new.min.js"></script>
	<script type="text/javascript">
	
		var table_data=parent.$table.bootstrapTable('getSelections');
	
		if(table_data.length >0){
			
			$('#qk_name').val(table_data[0].qk_name);
			$('#qk_id').val(table_data[0].qk_id);
			$('#period_name').val(table_data[0].period_name);
			$('#period_name_jh').val(table_data[0].period_name_jh);
			$('#instance_tm').val(table_data[0].instance_tm);
			$('#instance_price').val(table_data[0].instance_price);
			if(table_data[0].start_sd_date!=null&&table_data[0].start_sd_date!=''){
				var start_sd_date = getTableDate(table_data[0].start_sd_date);
				$('#start_sd_date').val(start_sd_date);
			}
			if(table_data[0].end_sd_date!=null&&table_data[0].end_sd_date!=''){
				var end_sd_date = getTableDate(table_data[0].end_sd_date);
				$('#end_sd_date').val(end_sd_date);
			}
			if(table_data[0].end_bd_date!=null&&table_data[0].end_bd_date!=''){
				var end_bd_date = getTableDate(table_data[0].end_bd_date);
				$('#end_bd_date').val(end_bd_date);
			}
			//$('#start_sd_date').val(table_data[0].start_sd_date);
			//$('#end_sd_date').val(table_data[0].end_sd_date);
			//$('#end_bd_date').val(table_data[0].end_bd_date);
			
			if(table_data[0].pub_date!=null&&table_data[0].pub_date!=''){
				var pub_date = getTableDate(table_data[0].pub_date);
				$('#pub_date').val(pub_date);
			}
			
			//$('#pub_date').val(table_data[0].input_date);
			$('#mem').val(table_data[0].mem);
			
// 	 		$.each(table_data[0], function(idx, obj) {
// 				if(obj.visible==0){
// 					obj.visible=false;
// 				}else if(obj.visible==1){
// 					obj.visible=true;
// 				}
// 				if(obj.sortable==0){
// 					obj.sortable=false;
// 				}else if(obj.sortable==1){
// 					obj.sortable=true;
// 				}
// 			});
		}
// 		else{
// 			console.log("table_data="+table_data.length);
// 		}
		
		function  getTableDate(timestamp){
			const date = new Date(timestamp); // 创建一个日期对象

			const year = date.getFullYear();
			const month = ('0' + (date.getMonth() + 1)).slice(-2); // 月份是从0开始的，所以需要+1，并且需要补齐为两位数
			const day = ('0' + date.getDate()).slice(-2); // 日期也需要补齐为两位数
// 			const hours = ('0' + date.getHours()).slice(-2); // 小时也需要补齐为两位数
// 			const minutes = ('0' + date.getMinutes()).slice(-2); // 分钟也需要补齐为两位数
// 			const seconds = ('0' + date.getSeconds()).slice(-2); // 秒数也需要补齐为两位数

			const formattedDate = year + "-" + month + "-" + day;

			return formattedDate;
		}
		
		$(document).ready(function () {
			
			$(".layer-date").each(function(){
				inistal_one_data('#'+$(this).attr('id'));
			});
			
			
			$('#save').on('click', function () {
				// 1. 获取并校验采购期次名称
			    var periodName = $('#period_name').val();
			    var reg = /^\d{8}$/; // 匹配严格的8位纯数字
			    
			    if (!reg.test(periodName)) {
			        // 使用项目中现有的 layer 组件弹出提示
			        layer.msg('采购期次名称必须为8位纯数字！', {icon: 5, anim: 6}); // icon:5 错误图标, anim:6 抖动效果
			        // 将焦点定位回输入框，方便用户修改
			        $('#period_name').focus();
			        return false; // 终止后续的表单提交
			    }
				if(!has_null($('#form')))
					ajax_function("addProductInstance","post",$('#form').serialize(),'新增成功');		
			 });
			//子元素滚动到底，父元素不随着滚动
			$('.tab-content').scrollUnique();
			//加载字典数据
			get_dictionary("${context}",null);
		});
		
		/*
		// 绑定回车事件(自动填充供应商和商品名)
		  $('#qk_name').on('keydown', function(e) {
		    if (e.which === 13) { // 13 是回车键的 keyCode
		      e.preventDefault();
		      getProductDetail();
		    }
		  });*/
		// 绑定回车和失去焦点事件(自动填充供应商和商品名)
		  $('#qk_name').on('keydown', function(e) {
		      if (e.which === 13) { // 13 是回车键的 keyCode
		          e.preventDefault();
		          getProductDetail();
		      }
		  }).on('blur', function() {
		      // 失去焦点时触发查询
		      // 增加一个小判断，避免输入框为空时也去发无效的 Ajax 请求
		      if ($(this).val().trim() !== "") {
		          getProductDetail();
		      }
		  });
		    
		   function getProductDetail(){
			   var json_obj_data={};
			   if($('#qk_name').val()!=null&&$('#qk_name').val()!=""){
				   json_obj_data['qk_name'] =$('#qk_name').val();
			   }
       	   
			   $.ajax({
			          type: "post",
			          contentType: "application/json",          // 明确指定请求体格式
			          url: "${context}/bk/basic/getProductList",
			          data: JSON.stringify(json_obj_data),
			          dataType: 'JSON',
			          success: function (data) {
			          	if(data.total==0){
			          		alert("编号未搜索到商品，请检查编号");
			          	}else if(data.total==1){
			          		$('#qk_id').val(data.rows[0].qk_id);
			          		$('#qk_name').val(data.rows[0].qk_name);
			          		//alert("商品资料已填充");
			          	}else if(data.total>1){
			          		open_layer(2,"选择明细","invoiceInstanceItemSelect",['1200px', '800px'],false);
			          	}
			          },
			          error: function (data) {
			          	console.log(data);
			          }
			      });	
		    }
	</script>
</html>