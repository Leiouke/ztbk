		/**
		 * 删除汇总报出临时表数据
		 * 
		 * 
		 */
		@RequestMapping(value="/deleteQkBdItemPeriodList")
		@ResponseBody
	    public Object deleteQkBdItemPeriodList(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request)throws JsonProcessingException{
			
			String[] inc_nos = request.getParameterValues("inc_nos");
			if(inc_nos != null && inc_nos.length > 0){
				for(int i=0;i<inc_nos.length;i++){
					String qkBdOut_guid = (String)httpSession.getAttribute("qkBdOut_guid");
					postData.put("guid", qkBdOut_guid);
					
					// 入参, 注意按照顺序
					String paramNames[] = {"guid","inc_no"};
					// 加入sp的名称
					postData.put("spName", "n_bk_qk_bd_item_period_temp_delete");
					
					postData.put("inc_no", inc_nos[i]);
					
					//System.out.println("inc="+inc_nos[i]);
					
					int code = baseService.doCallSp(postData, paramNames, null);
					
					if (code != 0) {
						return this.getAjaxResult(code);
					}
				}
			}
			return "{\"success\":true}";
	    }
		
