		public qkBdOutController() {
			todayBdFactoryQueryHeadConfig = new GridHeadConfig(todayBdFactoryQueryId,true,false,true,false);
			todayBdFactoryQueryHeadConfig.setOperatorWidth(100);
			
			factoryCanBdQueryHeadConfig = new GridHeadConfig(factoryCanBdQueryId,true,false,false,false);
			factoryCanBdQueryHeadConfig.setOperatorWidth(100);
			
			factoryCanOtherBdQueryHeadConfig = new GridHeadConfig(factoryCanOtherBdQueryId,true,false,false,false);
			factoryCanOtherBdQueryHeadConfig.setOperatorWidth(100);
			
			factoryCanPeriodBdQueryHeadConfig = new GridHeadConfig(factoryCanPeriodBdQueryId,true,true,true,false);
			factoryCanPeriodBdQueryHeadConfig.setOperatorWidth(100);
			
			factoryCanBlBdQueryHeadConfig = new GridHeadConfig(factoryCanBlBdQueryId,true,false,false,false);
			factoryCanBlBdQueryHeadConfig.setOperatorWidth(100);
			
//			bdRelatedZdQueryHeadConfig = new GridHeadConfig(bdRelatedZdQueryId,true,false,true,false);
//			bdRelatedZdQueryHeadConfig.setOperatorWidth(100);
		}
		
		/**
		 * 进入汇总报出界面
		 * 
		 * @return
		 * @throws JsonProcessingException 
		 */
		@RequestMapping(value="/qkBdOutManage")  // 这里不写method, 说明既可以post也可以get
	    public ModelAndView qkBdOutManage(HttpSession httpSession) throws JsonProcessingException{
	        ModelAndView mv = new ModelAndView();
	        mv.setViewName("bd/bdOut/qkBdOutManage");
	        String tableHeader = this.getTableHeader(httpSession,todayBdFactoryQueryHeadConfig);
	        mv.addObject("tableHeader", tableHeader);
			mv.addObject("queryId", todayBdFactoryQueryId);
	        return mv;
	    }
		
		/**
		 * 获得汇总报出数据
		 * 
		 * @return
		 */
		@RequestMapping(value="/getQkBdOutList")
		@ResponseBody
		public Object getQkBdOutList(@RequestBody Map postData, HttpSession httpSession) {
			return this.getTableDataList(postData, todayBdFactoryQueryId);
		}
		
		//-----------------------------------切片报订---------------------------------------------
		
		/**
		 * 修改汇总报出页面（切片）
		 * @throws JsonProcessingException 
		 * 
		 * 
		 */
		@RequestMapping(value="/qkBdOutEdit",method=RequestMethod.GET)
	    public ModelAndView qkBdOutEdit(@RequestParam Map postData,HttpSession httpSession) throws JsonProcessingException{  // 注意这个postData里面已经包含了id的字段值
	        ModelAndView mv = new ModelAndView();        
	        // 单记录查询
			String tableHeader = this.getTableHeader(httpSession, factoryCanBdQueryHeadConfig);
			mv.addObject("tableHeader", tableHeader);
			mv.addObject("queryId", factoryCanBdQueryId);
			mv.setViewName("bd/bdOut/qkBdOutEditManage");
			mv.addObject("f_id", (String)postData.get("f_id"));
			mv.addObject("f_department", (String)postData.get("f_department"));
			mv.addObject("pre_bd_date", (String)postData.get("pre_bd_date"));
			mv.addObject("next_bd_date", (String)postData.get("next_bd_date"));
			
			//生成GUID
			String qkBdOut_guid=GuidUtil.create32Guid();
			httpSession.setAttribute("qkBdOut_guid", qkBdOut_guid);
			
	        return mv;
	    }
		
		/**
		 * 获得汇总报出临时表数据（可报出数据）
		 * 
		 * @return
		 */
		@RequestMapping(value="/getQkFactoryCanBdList")
		@ResponseBody
		public Object getQkFactoryCanBdList(@RequestBody Map postData, HttpSession httpSession) {
			
			String qkBdOut_guid = (String)httpSession.getAttribute("qkBdOut_guid");
			postData.put("guid", qkBdOut_guid);
			
			//传入临时表
			// 入参, 注意按照顺序
			String paramNames[] = new String[]{"guid",
					"start_time",
				    "end_time",
				    "f_id",
				    "is_kind_id",
					"Reset",
					"bd_pici",
					"byDay"};
			// 加入sp的名称
			postData.put("spName", "Up_CreateBd_Preview");
								
			int code = baseService.doCallSp(postData, paramNames, null);
			
			return this.getTableDataList(postData, factoryCanBdQueryId);
		}
		
		/**
		 * 新增汇总报出
		 * 
		 * @throws JsonProcessingException 
		 * 
		 * 
		 */
		@RequestMapping(value="/addQkBd")
		@ResponseBody
	    public Object addQkBd(@RequestParam Map postData,HttpSession httpSession){
			
			String qkBdOut_guid = (String)httpSession.getAttribute("qkBdOut_guid");
			postData.put("guid", qkBdOut_guid);
			
			User user=(User)httpSession.getAttribute("user");
			postData.put("o_id_input", user.getAccount());
			
			// 入参, 注意按照顺序
			String paramNames[] = {"guid",
					"f_id",
					"start_time",
					"end_time",
					"o_id_input",
					"station_id",
					"station_id_aim",
				    "is_kind_id",
					"Reset"
			};
			
			// 出参, 有顺序
			String returnNames[] = {"bd_id"};
			
			postData.put("spName", "Up_CREATEBd_QkScroll");
			
			int code = baseService.doCallSp(postData, paramNames, returnNames);		
			if (code != 0) {
				return this.getAjaxResult(code);
			}
			return "{\"success\":true}";
	    }
		
