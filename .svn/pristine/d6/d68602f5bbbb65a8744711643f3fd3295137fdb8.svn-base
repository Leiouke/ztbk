			          "is_destroy",
			          "destroy_date",
			          "o_id_destroy",
			          "memo",
			          "receipts_class",
			          "bd_pici",
			          "notrigger",
			          "station_id_aim",
			          "start_date",
			          "end_date"
			          };
			
			// 出参, 有顺序
			String returnNames[] = {"bd_id"};
			
			postData.put("spName", "n_bk_qk_bd_new");
			
			int code = baseService.doCallSp(postData, paramNames, returnNames);		
			if (code != 0) {
				return this.getAjaxResult(code);
			}
			return "{\"success\":true}";
	    }
		
}
