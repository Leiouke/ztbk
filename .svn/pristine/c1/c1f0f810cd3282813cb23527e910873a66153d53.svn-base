@Controller
@RequestMapping("/bk/bd")
public class qkDhController extends ZtbkServiceController {
	private int qkDhManageQueryId = 10000018;	
	private GridHeadConfig qkDhManageGridHeadConfig;
	
	private int qkDhOneQueryId = 10000018;	

	private int qkDhItemQueryId = 10000019;	
	private GridHeadConfig qkDhItemGridHeadConfig;
	
	/**
	 * 初始化工作, 修改内容后需要重新启动服务生效
	 * 
	 */
	public qkDhController(){
		qkDhManageGridHeadConfig = new GridHeadConfig(qkDhManageQueryId,true,false,true,false);
		qkDhManageGridHeadConfig.setOperatorWidth(80);
		
		qkDhItemGridHeadConfig = new GridHeadConfig(qkDhItemQueryId,true,true,true,false);
	}
	/**
	 * 进入到货管理界面
	 * 
	 * @return
	 * @throws JsonProcessingException 
	 */
	@RequestMapping(value="/qkDhManage")  // 这里不写method, 说明既可以post也可以get
    public ModelAndView qkDhManage(HttpSession httpSession) throws JsonProcessingException{
        ModelAndView mv = new ModelAndView();
        mv.setViewName("bd/qkDh/qkDhManage");
        String tableHeader = this.getTableHeader(httpSession,qkDhManageGridHeadConfig);
        mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", qkDhManageQueryId);
        return mv;
    }
	
	/**
	 * 获得动态列表数据-到货管理 by fjs
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/getQkDhManageList")
	@ResponseBody
	public Object getDhBatchManageList(@RequestBody Map postData){
		return this.getTableDataList(postData,qkDhManageQueryId);
	}
	
	/**
	 * 新增报刊到货页面 by fjs
	 * 
	 * 
	 */
	@RequestMapping(value="/paperDhAdd",method=RequestMethod.GET)
    public ModelAndView paperDhAdd(HttpSession httpSession)throws JsonProcessingException{
        ModelAndView mv = new ModelAndView();
        mv.setViewName("bd/qkDh/paperDhAdd");
        return mv;
    }
	
	/**
	 * 新增报刊到货操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/addPaperDh")
	@ResponseBody
    public Object addPaperDh(@RequestParam Map postData,HttpSession httpSession) throws EncryptedDocumentException, InvalidFormatException, IOException {	
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"subscribe_date", "ps_date", "qk_attribute", "qk_dh_id", "station_id"};
		// 加入sp的名称
		postData.put("spName", "Up_Auto_Insert_qkdh");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("created_by", user.getUserName());
		
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 报刊到货明细界面
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/paperDhItem", method=RequestMethod.GET)
    public ModelAndView paperDhItem(HttpServletRequest request,HttpSession httpSession) throws JsonProcessingException {
        ModelAndView mv = new ModelAndView();
        mv.setViewName("bd/qkDh/paperDhItem");
        // 从请求参数获取 qk_dh_id
        String qk_dh_id = request.getParameter("qk_dh_id");
        httpSession.setAttribute("qk_dh_id", qk_dh_id);
        String tableHeader = this.getTableHeader(httpSession,qkDhItemGridHeadConfig);
        mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", qkDhItemQueryId);
        return mv;
    }
	
	/**
	 * 获得动态列表数据-报刊到货明细
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/getPaperDhItemList")
	@ResponseBody
	public Object getPaperDhItemList(@RequestBody Map postData){
		return this.getTableDataList(postData, qkDhItemQueryId);
	}
	
