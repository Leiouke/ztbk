	/**
	 * 上架打印确认操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/magOnshelfCommit")
	@ResponseBody
    public Object magOnshelfCommit(@RequestParam Map postData,HttpSession httpSession) throws EncryptedDocumentException, InvalidFormatException, IOException {	
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"qk_dh_id", "o_id_input"};
		// 出参, 注意按照顺序
		String returnNames[] = new String[]{"upshelf_id"};
		// 加入sp的名称
		postData.put("spName", "Up_Auto_Insert_UpShelf");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_input", user.getUserName());
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		int print_add_code = qkDhttPrintCountAdd(postData,"1");//'0':贴头打印；'1'：上架单打印
		if (print_add_code != 0) {
			return this.getAjaxResult(print_add_code);
		}
		
		return "{\"success\":true}";
    }

	/**
	 * 贴头打印确认操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/qkDhttCommit")
	@ResponseBody
    public Object qkDhttCommit(@RequestParam Map postData,HttpSession httpSession) throws EncryptedDocumentException, InvalidFormatException, IOException {	
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"qk_dh_id","PRINT_BZ","Address_date"};
		// 出参, 注意按照顺序
		String returnNames[] = new String[]{"newid"};
		// 加入sp的名称
		postData.put("spName", "Up_Auto_INSERT_QKPRINT");
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		int print_add_code = qkDhttPrintCountAdd(postData,"0");//'0':贴头打印；'1'：上架单打印
		if (print_add_code != 0) {
			return this.getAjaxResult(print_add_code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 
	 * 增加打印次数
