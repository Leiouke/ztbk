	/**
	 * 插入临时表数据
	 * 
	 * 
	 */
	@RequestMapping(value="/doMagDhItemPullIn")
	@ResponseBody
    public Object doMagDhItemPullIn(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession){
		
		String qk_dh_guid=(String)httpSession.getAttribute("qk_dh_guid");
		
		for(Map<String,Object> map:postData){
			Map<String,Object> sp_map = new HashMap<String,Object>();
			sp_map.put("guid", qk_dh_guid);
			sp_map.put("inv_id", map.get("inv_id"));
			sp_map.put("ItemExclusiveCode", map.get("ItemExclusiveCode"));
			
			sp_map.put("spName","n_qk_instance_dh_item_temp_new");
			
			// 入参, 注意按照顺序
			String paramNames[] = {"inv_id","ItemExclusiveCode","guid"};
			
			int code = baseService.doCallSp(sp_map, paramNames, null);
			
			if (code != 0) {
				return this.getAjaxResult(code);
			}
		}
		return "{\"success\":true}";
    }
	
	/**
	 * 修改临时表信息
	 * @return
	 */
	@RequestMapping(value="/eidtMagDhItemTemp")
	@ResponseBody
	public Object eidtMagDhItemTemp(@RequestParam Map postData) {
		
		// 加入sp的名称
		postData.put("spName", "n_qk_instance_dh_item_temp_update");
						
		String paramNames[] = {"guid","inc_no","h_amount_dh","instance_tm","period_name"};
				
						
		int code=baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
	}
	
	/**
	* 删除临时表明细
	* 
	* param postData
	* return
	*/
	@RequestMapping(value="/deleteMagDhItemTemp")
	@ResponseBody
	public Object deleteMagDhItemTemp(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request){
		
		//放入GUID
		String qk_dh_guid=(String)httpSession.getAttribute("qk_dh_guid");
		postData.put("guid", qk_dh_guid);
				
		String[] inc_nos = request.getParameterValues("inc_no_ids");
		if(inc_nos != null && inc_nos.length > 0){
			for(int i=0;i<inc_nos.length;i++){
				// 入参, 注意按照顺序
				String paramNames[] = new String[]{"guid", "inc_no"};
				// 加入sp的名称
				postData.put("spName", "n_qk_instance_dh_item_temp_delete");					
				
				postData.put("inc_no", inc_nos[i]);

				int code = baseService.doCallSp(postData, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}	
		
		return "{\"success\":true}";
	 }
	
