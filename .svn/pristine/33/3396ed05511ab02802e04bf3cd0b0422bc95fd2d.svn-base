	/**
	 * 杂志到货修改页面
	 * @throws JsonProcessingException 
	 * 
	 * 
	 */
	@RequestMapping(value="/toMagDhItemEdit",method=RequestMethod.GET)
    public ModelAndView toMagDhItemEdit(@RequestParam Map postData,HttpSession httpSession) throws JsonProcessingException{  // 注意这个postData里面已经包含了id的字段值
        ModelAndView mv = new ModelAndView();        
        // 单记录查询
		Map<String, Object> oneQuery = baseService.getOneQuery(qkDhOneQueryId, postData);
		mv.addObject("oneJson", JsonUtil.mapToString(oneQuery));
        mv.setViewName("bd/qkDh/magDhEdit");
        
        String qk_dh_guid=GuidUtil.create32Guid();
        httpSession.setAttribute("qk_dh_guid", qk_dh_guid);
        
        String tableHeader = this.getTableHeader(httpSession,qkDhItemTempGridHeadConfig);
		mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", qkDhItemTempQueryId);
        
        // 入参, 注意按照顺序
 		String paramNames[] = {"qk_dh_id", "guid"};
 		// 加入sp的名称
 		postData.put("spName", "n_qk_instance_dh_item_temp_todata");
 		
        httpSession.setAttribute("qk_dh_guid", qk_dh_guid);
 		postData.put("guid", qk_dh_guid);
 		
 		int code = baseService.doCallSp(postData, paramNames, null);
		
        return mv;
    }
	
