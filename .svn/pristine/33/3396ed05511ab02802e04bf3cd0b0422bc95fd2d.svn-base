	public qkDhController(){
		qkDhManageGridHeadConfig = new GridHeadConfig(qkDhManageQueryId,true,false,true,false);
		qkDhManageGridHeadConfig.setOperatorWidth(80);
		
		qkDhItemGridHeadConfig = new GridHeadConfig(qkDhItemQueryId,true,false,true,false);
		
		magDhItemPullInGridHeadConfig = new GridHeadConfig(magDhItemPullInQueryId,true,true,false,false);
		
		qkDhItemFFGridHeadConfig = new GridHeadConfig(qkDhItemFFQueryId,true,false,false,false);
		
		qkDhItemTempGridHeadConfig = new GridHeadConfig(qkDhItemTempQueryId,true,true,true,false);
		qkDhItemTempGridHeadConfig.setOperatorWidth(80);
	}
