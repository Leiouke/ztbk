	/**
	 * 删除操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteClient")
	@ResponseBody
    public Object deleteClient(@RequestParam Map postData,HttpSession httpSession){
		User user=(User)httpSession.getAttribute("user");		
		postData.put("delete_person", user.getAccount());
		
		// 入参, 注意按照顺序
		String paramNames[] = {"c_id","delete_person"};
		// 加入sp的名称
		postData.put("spName", "n_bk_db_clients_delete");
		int code = baseService.doCallSp(postData, paramNames, null);		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		return "{\"success\":true}";
    }
	
	/**
	 * 修改页面
	 * @throws JsonProcessingException 
	 * 
	 * 
	 */
	@RequestMapping(value="/clientEdit",method=RequestMethod.GET)
    public ModelAndView clientEdit(@RequestParam Map postData,HttpSession httpSession) throws JsonProcessingException{  // 注意这个postData里面已经包含了id的字段值
        ModelAndView mv = new ModelAndView();        
        // 单记录查询
		Map<String, Object> oneQuery = baseService.getOneQuery(clientOneQueryId, postData);
		
		ObjectMapper mapper = new ObjectMapper();
		mv.addObject("oneJson", JsonUtil.mapToString(oneQuery));
        mv.setViewName("basic/client/clientEdit");
        
		//地址信息表
        String tableHeader_address = this.getTableHeader(httpSession,addressGridHeadConfig);
		mv.addObject("tableHeader_address", tableHeader_address);		
		mv.addObject("queryId_address", this.addressQueryId);
		
		//客户事件表
        String tableHeader_content = this.getTableHeader(httpSession,contentGridHeadConfig);
		mv.addObject("tableHeader_content", tableHeader_content);		
		mv.addObject("queryId_content", this.contentQueryId);
		
		//银行表
		String tableHeader_bank = this.getTableHeader(httpSession,bankGridHeadConfig);
		mv.addObject("tableHeader_bank", tableHeader_bank);		
		mv.addObject("queryId_bank", this.bankQueryId);

        return mv;
    }
	
