	private int clientManageQueryId = 10000002;		//客户信息表头查询
	private GridHeadConfig clientManageGridHeadConfig;
	
	private int clientOneQueryId = 10000002; //单条查询
	
	private int addressQueryId = 10000011;  //地址信息表
	private GridHeadConfig addressGridHeadConfig;
	
	private int contentQueryId = 10000012;  //事件信息表
	private GridHeadConfig contentGridHeadConfig;
	
	private int provinceQueryId = 10000040; //省份信息
	
	private int cityQueryId = 10000041; //城市信息
	
	private int arrearsQueryId = 10000042; //地区信息
	
	private int bankQueryId = 5000005;	   //银行信息
	private GridHeadConfig bankGridHeadConfig;

	/**
	 * 初始化工作, 修改内容后需要重新启动服务生效
	 * 
	 */
	public BkClientController(){
		clientManageGridHeadConfig = new GridHeadConfig(clientManageQueryId,true,false,true,false);
		clientManageGridHeadConfig.setOperatorWidth(80);
		clientManageGridHeadConfig.setLineNoWidth(40);
		
		addressGridHeadConfig = new GridHeadConfig(addressQueryId,true,false,true,false);
		contentGridHeadConfig = new GridHeadConfig(contentQueryId,true,false,true,false);
		
		bankGridHeadConfig = new GridHeadConfig(bankQueryId,true,false,true,false);
	}
	
	
	/**
	 * 客户管理界面
	 * 
	 * @param httpSession
	 * @return
	 * @throws JsonProcessingException
	 */
	@RequestMapping(value="/clientManage",method=RequestMethod.GET)
    public ModelAndView clientManage(HttpSession httpSession) throws JsonProcessingException {
        ModelAndView mv = new ModelAndView();
        mv.setViewName("basic/client/clientManage");
        String tableHeader = this.getTableHeader(httpSession, clientManageGridHeadConfig);
		mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", clientManageQueryId);
        return mv;
    }
	
