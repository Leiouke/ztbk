	 * param postData
	 * return
	 */
	@RequestMapping(value="/addClientBank")
	@ResponseBody
    public Object addClientBank(@RequestParam Map postData){
		// 入参, 注意按照顺序
		String paramNames[] = {"f_id","f_companyName","f_registMark","f_companyAddress",
				"f_companyPhone","f_payment","f_bank","f_account","swift_code","iban","aba","f_default","f_bankAddress","f_bankPhone","memo","my_bank","my_account",
				"kp_type", "tax_rate", "is_item" , "kp_content", "kp_amount", "kp_unit"};	
		// 加入sp的名称
		postData.put("spName", "u_basic_bank_new");
		
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		return "{\"success\":true}";
    }
	
