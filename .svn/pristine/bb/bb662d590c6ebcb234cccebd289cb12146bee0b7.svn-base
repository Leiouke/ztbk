	/**
	 * 提交出库通知单
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/commitOutBound")
	@ResponseBody
    public Object commitOutBound(@RequestParam Map postData,HttpSession httpSession){
		
		User user=(User)httpSession.getAttribute("user");
		
		postData.put("o_id_input", user.getAccount());
		
		// 入参, 注意按照顺序
		String paramNames_commit[] = {
							 "downshelf_id",
					         "o_id_input"};
		// 加入sp的名称
		postData.put("spName", "n_bk_qk_downshelf_commit");
					
		int code_commit = baseService.doCallSp(postData, paramNames_commit, null);
			
		if (code_commit != 0) {
			return this.getAjaxResult(code_commit);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 修改临时表明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/updateOutBoundItemTemp")
	@ResponseBody
    public Object updateOutBoundItemTemp(@RequestParam Map postData,HttpSession httpSession) {
		String outBound_guid = (String)httpSession.getAttribute("outBound_guid");
		
		postData.put("guid", outBound_guid);
		
		// 入参, 注意按照顺序
		String paramNames[] = {"guid", "inc_no","h_amount"};
		// 加入sp的名称
		postData.put("spName", "n_bk_qk_downshelf_item_temp_update");
		
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}

		return "{\"success\":true}";
    }

}
