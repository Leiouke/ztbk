	/**
	 * 新增销售发票操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/addSaleInvoice")
	@ResponseBody
    public Object addSaleInvoice(@RequestParam Map postData,HttpSession httpSession) {		
		
		//蓝票新增
		postData.put("is_red", false);
		postData.put("hedging_kp_id", "");
		
		// 入参, 注意按照顺序
		String paramNames[] = {"guid", "c_id","is_duty_free","invoice_type","tax_rate","amount","tax_money","total_money","memo","o_id_input","is_item_kp","o_id_receiver","kp_mail","is_red","hedging_kp_id"};
		// 出参, 有顺序
		String returnNames[] = {"kp_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_invoice_kp_new");
		
		String saleInvoice_guid=(String)httpSession.getAttribute("saleInvoice_guid");
		postData.put("guid", saleInvoice_guid);
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_input", user.getAccount());
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");	
		postData.put("is_to_edit", 0);
		code = do_sp_sale_invoice_statement_item_calculate(postData);				
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		// 以下获得出参值
		//System.out.println(postData.get("kp_id"));
		return "{\"success\":true}";
    }
	
