   	/**
	 * 引入明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/pullAgentFinanceFhshItem")
	@ResponseBody
    public Object pullAgentFinanceFhshItem(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession,HttpServletRequest request){	
		String finance_agent_fhsh_guid=(String)httpSession.getAttribute("finance_agent_fhsh_guid");
		if(postData!=null&&postData.size()>0){
			for(Map<String,Object> inv_map:postData){
				// 入参, 注意按照顺序
				String paramNames[] = {"guid","inv_id","fh_money"};
				// 加入sp的名称
				inv_map.put("spName", "u_finance_fhsh_item_pullin");
				
				inv_map.put("guid", finance_agent_fhsh_guid);
				
				int code = baseService.doCallSp(inv_map, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}			
		
		return "{\"success\":true}";
    }
	
	/**
	 * 删除明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteAgentFinanceFhshItem")
	@ResponseBody
    public Object deleteAgentFinanceFhshItem(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request){		
		String finance_agent_fhsh_guid=(String)httpSession.getAttribute("finance_agent_fhsh_guid");
		postData.put("guid", finance_agent_fhsh_guid);
		
		String[] inv_ids=request.getParameterValues("inv_ids");
		if(inv_ids!=null&&inv_ids.length>0){
			for(int i=0;i<inv_ids.length;i++){
				// 入参, 注意按照顺序
				String paramNames[] = {"guid","inv_id"};
				// 加入sp的名称
				postData.put("spName", "u_finance_fhsh_item_delete");					
				
				postData.put("inv_id", inv_ids[i]);

				int code = baseService.doCallSp(postData, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}	
		
		return "{\"success\":true}";
    }
	
