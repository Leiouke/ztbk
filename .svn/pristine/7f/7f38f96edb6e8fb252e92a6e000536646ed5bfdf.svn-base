	/**
	 * 新增申汇操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/addFinanceAgentFhsh")
	@ResponseBody
    public Object addFinanceAgentFhsh(@RequestParam Map postData,HttpSession httpSession){		
		// 入参, 注意按照顺序
		String paramNames[] = {"guid","f_id","o_id_operator","o_id_input","fh_date","currency","fh_money","invoice_amount",
				"total_money","region_catagory","bank_id","is_advance","is_bail","memo","fw_mode","fhsh_family","c_id"};
		// 出参, 有顺序
		String returnNames[] = {"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_new");
		
		String finance_agent_fhsh_guid=(String)httpSession.getAttribute("finance_agent_fhsh_guid");
		postData.put("guid", finance_agent_fhsh_guid);
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_input", user.getAccount());
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		postData.remove("paramNames");
		code = do_sp_invoice_sw_calculate(postData);				
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");
		code=do_sp_finance_item_classfy(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");
		code=do_sp_finance_purchase_item_classfy(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		// 以下获得出参值
		//System.out.println(postData.get("fe_id"));
		return "{\"success\":true}";
    }
	
	//计算发票已申汇金额
	private int do_sp_invoice_sw_calculate(Map postData){
		String paramNames[] = {"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_invoice_sw_calculate");
		return baseService.doCallSp(postData, paramNames, null);
	}
	
