	/**
   	 * 获得动态列表数据-引入支出单发票明细
   	 * 
   	 * param postData
   	 * return
   	 */
   	@RequestMapping(value="/getClientPayItemItemPullList")
   	@ResponseBody
   	public Object getClientPayItemItemPullList(@RequestBody Map postData,HttpSession httpSession) {
   		// 获得权限代码参数
   		AccessControlUtil.accessParams(postData, httpSession);
