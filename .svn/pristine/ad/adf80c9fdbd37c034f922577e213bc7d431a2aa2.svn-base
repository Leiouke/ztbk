// 				}
// 				sum_count+=1;
// 				if(row.real_price==undefined){
// 					sum_real_money+=0;
// 				}else{
// 					sum_real_money+=row.real_price;
// 				}
// 			});
//  			sum_money=sum_money.toFixed(2);
//  			sum_real_money=sum_real_money.toFixed(2);
//  			$("input[name='total_money']").val(sum_money);
//  			$("input[name='total_count']").val(sum_count);
//  			$("input[name='total_amount']").val(sum_amount);
//  			$("input[name='total_real_money']").val(sum_real_money);
// 		}});
		
		//表格配置 layer
		var $config=$("#config");
		
		table_column_config_layer($config,2,'表格属性配置','${context}/csu/columnConfig?queryId=${queryId}');
		
		$('#tableTool').find('select').change(function () {
			 $('#table').bootstrapTable('refreshOptions',{exportDataType: $(this).val()});
	    });
		
		//自动搜索填补
		initialize_bsSuggest_bk_factory("${context}", "f_department", "f_id");
		initialize_bsSuggest_fc_user("${context}", "o_id_receiver_name", "o_id_receiver");      // 放用户信息
		
		if('${f_id}'!=''){
			 $("input[name='f_id']").val('${f_id}');
		 }
		 if('${f_department}'!=''){
			 var f_department= '${f_department}';
			 $("input[name='f_department']").val(f_department);
		 }
		 
		 console.log("pre_bd_date="+'${pre_bd_date}');
		 
// 		 if('${pre_bd_date}'!=''&&'${pre_bd_date}'!=null){
			 //console.log("pre_bd_date="+'${pre_bd_date}');
			 //$("input[name='start_time']").val('${pre_bd_date}');
			 if('${qk_bd_regular}' != "01"){//非按月报订填入结束日期
				 $("input[name='start_time']").val('${next_bd_date}');
			 }else{//按月报订填入当月1月1日
				 const now = new Date();
				 // 当月第一天
				 const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
				 const year = firstDay.getFullYear();
			     const month = String(firstDay.getMonth() + 1).padStart(2, '0');
			     const day = String(firstDay.getDate()).padStart(2, '0');
			     
			     $("input[name='start_time']").val(year+"-"+month+"-"+day);
			 }
			 
// 		 }
		 
		 if('${next_bd_date}'!=''&&'${next_bd_date}'!=null){
			 //console.log("next_bd_date="+'${next_bd_date}');
			 //$("input[name='end_time']").val('${next_bd_date}');
			 if('${qk_bd_regular}' == "03"){//按周报订加一周
				 let date = addWeeksFormatted('${next_bd_date}',1);
				 $("input[name='end_time']").val(date);
			 }else if('${qk_bd_regular}' == "04"){//按日报订的加一天
				let date = addWeeksFormatted('${next_bd_date}',1/7);
				 $("input[name='end_time']").val(date);
			 }else if('${qk_bd_regular}' == "02"){//半月报订价两周
				 let date = addWeeksFormatted('${next_bd_date}',2);
				 $("input[name='end_time']").val(date);
			 }else if('${qk_bd_regular}' == "01"){//按月报订获得当月的最后一天
				 const now = new Date();
				 // 当月第一天
				 const lastDay = new Date(now.getFullYear(), now.getMonth() + 1, 0);
				 const year = lastDay.getFullYear();
			     const month = String(lastDay.getMonth() + 1).padStart(2, '0');
			     const day = String(lastDay.getDate()).padStart(2, '0');
			     
			     $("input[name='end_time']").val(year+"-"+month+"-"+day);
			 }
		 }
		 if('${qk_bd_regular}'!=''){
			 var qk_bd_regular= '${qk_bd_regular}';
			 setTimeout(function(){
				 $('#qk_bd_regular').val(qk_bd_regular);
			 	}
			 ,1000);
		 }
		 
		 //增加日期周数方法
		 function addWeeksFormatted(date, weeks) {
	        const dateObj = new Date(date);
	        dateObj.setDate(dateObj.getDate() + (weeks * 7));
	        
	        const year = dateObj.getFullYear();
	        const month = String(dateObj.getMonth() + 1).padStart(2, '0');
	        const day = String(dateObj.getDate()).padStart(2, '0');
	        
	        return year+"-"+month+"-"+day;
    	}

	});
	</script>
