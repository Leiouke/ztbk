<!-- 									    <select name="receipts_class" class="form-control dictionary search-items" > -->
<!-- 									    	<option></option> -->
<!-- 									    </select> -->
<!-- 								  </div> -->
								  <div class="form-group inline-small">
									    <label >报刊类型：</label>
									    <select name="qk_attribute"  class="form-control  search-items" >
									    	<option value = "02">杂志</option>
									    </select>
								  </div>
								  <div class="form-group inline-small not-null">
								    <label >订阅日期：</label>
								    <input type="text" class="form-control  layer-date search-items date-type"  name="subscribe_date" id="subscribe_date">
								  </div>
								  <div class="form-group inline-small not-null">
