package com.cnpiecsb.np.finance.controller;

import java.util.Map;

import javax.servlet.http.HttpSession;

import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.ResponseBody;
import org.springframework.web.servlet.ModelAndView;

import com.cnpiecsb.common.util.JsonUtil;
import com.cnpiecsb.csu.controller.BaseServiceController;
import com.cnpiecsb.csu.entity.viewobject.GridHeadConfig;
import com.cnpiecsb.system.entity.User;
import com.fasterxml.jackson.core.JsonProcessingException;

@Controller
@RequestMapping("/np")
public class FhConfirmController extends BaseServiceController {
	private int fhConfirmManageQueryId = 5600009;
	private GridHeadConfig fhConfirmManageGridHeadConfig;
	
	private int fhConfirmManageOneQueryId = 5600009;
	
	/**
	 * 初始化工作, 修改内容后需要重新启动服务生效
	 * 
	 */
	public FhConfirmController(){
		fhConfirmManageGridHeadConfig=new GridHeadConfig(fhConfirmManageQueryId,true,false,true,false);
		fhConfirmManageGridHeadConfig.setOperatorWidth(120);
	}
	
	/**
	 * 获得动态列表数据-付汇确认列表
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/fhConfirmManage",method=RequestMethod.GET)
    public ModelAndView fhConfirmManage(HttpSession httpSession)throws JsonProcessingException {
        ModelAndView mv = new ModelAndView();
        mv.setViewName("np/fhConfirm/fhConfirmManage");
        String tableHeader = this.getTableHeader(httpSession,fhConfirmManageGridHeadConfig);
		mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", fhConfirmManageQueryId);
        return mv;
    }
	
	/**
	 * 获得动态列表数据-申汇审核列表
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/getFhConfirmManageList")
	@ResponseBody
	public Object getFinanceFhshVerifyManageList(@RequestBody Map postData){
		return this.getTableDataList(postData,fhConfirmManageQueryId);
	}
	
	/**
	 * 付汇确认编辑页面
	 * @throws JsonProcessingException 
	 * 
	 * 
	 */
	@RequestMapping(value="/fhConfirm",method=RequestMethod.GET)
    public ModelAndView fhConfirm(@RequestParam Map postData,HttpSession httpSession)throws JsonProcessingException {
		ModelAndView mv = new ModelAndView();
		// 单记录查询
		Map<String, Object> oneQuery = baseService.getOneQuery(fhConfirmManageOneQueryId, postData);		
		mv.addObject("oneJson", JsonUtil.mapToString(oneQuery));
        mv.setViewName("np/fhConfirm/fhConfirm");
//        String tableHeader = this.getTableHeader(httpSession,fhConfirmGridHeadConfig);
//		mv.addObject("tableHeader", tableHeader);
//		mv.addObject("queryId", fhConfirmQueryId);
        return mv;
    }
	
	/**
	 * 付汇确认操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/confirmFh")
	@ResponseBody
    public Object confirmFh(@RequestParam Map postData,HttpSession httpSession){
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_input", user.getAccount());
		int code = do_sp_shfh_pay_confirm(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		postData.remove("paramNames");
		code=do_sp_invoice_fw_calculate(postData);			
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");
		code=do_sp_fw_item_classify(postData);			
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");
		code=do_sp_against_rmb_item_classify(postData);			
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	//付汇确认
	private int do_sp_shfh_pay_confirm(Map postData){
		String paramNames[] = {"fh_id","pay_date","o_id_input","pay_money"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_pay_confirm");
		
		return baseService.doCallSp(postData, paramNames, null);
	}
	
	//计算已付汇金额
	private int do_sp_invoice_fw_calculate(Map postData){
		String paramNames[] = {"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_invoice_fw_calculate");
		
		return baseService.doCallSp(postData, paramNames, null);
	}
	
	/**
	 * 付汇撤销操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/returnFh")
	@ResponseBody
    public Object returnFh(@RequestParam Map postData,HttpSession httpSession){
		int code = do_sp_shfh_pay_withdraw(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		postData.remove("paramNames");
		
		code=do_sp_invoice_fw_calculate(postData);			
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		return "{\"success\":true}";
    }
	
	// 付汇撤销
	private int do_sp_shfh_pay_withdraw(Map postData){
		String paramNames[] = {"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_pay_withdraw");
		
		return baseService.doCallSp(postData, paramNames, null);
	}
	
	// 付汇明细分类汇总补充 
	private int do_sp_fw_item_classify(Map postData){
		String paramNames[] = new String[]{"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_fw_item_classify");
				
		return baseService.doCallSp(postData, paramNames, null);
	}
	
	// 代销预估的人民币冲销金额分摊
	private int do_sp_against_rmb_item_classify(Map postData){
		String paramNames[] = new String[]{"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_against_rmb_item_classfiy");
				
		return baseService.doCallSp(postData, paramNames, null);
	}
}
