	/**
	 * 新增刊期明细(单期)
	 * 
	 * @throws JsonProcessingException 
	 * 
	 * 
	 */
	@RequestMapping(value="/addQkZdSingleItemTempList")
	@ResponseBody
    public Object addQkZdSingleItemTempList(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession,HttpServletRequest request){
		
		//User user=(User)httpSession.getAttribute("user");
		 String qkZd_guid = (String)httpSession.getAttribute("qkZd_guid");
		 
		 if(postData!=null&&postData.size()>0){
				for(Map<String,Object> item_map:postData){				
					item_map.put("guid", qkZd_guid);
					item_map.put("h_amount", 1);
					item_map.put("real_price", 1*(int)item_map.get("h_price"));
					item_map.put("bd_amount",0);
					item_map.put("h_discount",1);
						
					// 入参, 注意按照顺序
					String paramNames[] = {"guid",         
					          "zd_id",
					          "qk_id",
					          "period_id",
					          "h_amount",
					          "stock_amount",
					          "tz_amouint",
					          "bd_amount",
					          "jh_amount",
					          "ps_amount",
					          "cw_type",
					          "h_price",
					          "real_price",
					          "jh_price",
					          "f_id",
					          "sort_number",
					          "memo",
					          "ItemExclusiveCode",
					          "zd_ItemExclusiveCode",
					          "tz_operator",
					          "tz_date",
					          "h_discount"
						       };
						
					item_map.put("spName", "n_bk_qk_zd_item_period_temp_new");
					
					int code = baseService.doCallSp(item_map, paramNames, null);		
					if (code != 0) {
						return this.getAjaxResult(code);
					}
				}
			}		

		return "{\"success\":true}";
    }
	
