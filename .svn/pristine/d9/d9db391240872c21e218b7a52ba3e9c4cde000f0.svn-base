	/**
	 * 修改订单页面（周期）
	 * @throws JsonProcessingException 
	 * 
	 * 
	 */
	@RequestMapping(value="/qkZdEdit",method=RequestMethod.GET)
    public ModelAndView qkZdEdit(@RequestParam Map postData,HttpSession httpSession) throws JsonProcessingException{  // 注意这个postData里面已经包含了id的字段值
        ModelAndView mv = new ModelAndView();        
        // 单记录查询
		Map<String, Object> oneQuery = baseService.getOneQuery(qkZdManageQueryId, postData);		
		mv.addObject("oneJson", JsonUtil.mapToString(oneQuery));
		mv.addObject("zd_id", (String)postData.get("zd_id"));
		String tableHeader = this.getTableHeader(httpSession, qkZdItemManageQueryHeadConfig);
		mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", qkZdItemManageQueryId);
		mv.setViewName("sd/qkZd/qkZdEditManage");
		
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"guid", "zd_id"};
		// 加入sp的名称
		postData.put("spName", "n_bk_qk_zd_item_period_temp_getsddata");
				
		String qkZd_guid=GuidUtil.create32Guid();
		httpSession.setAttribute("qkZd_guid", qkZd_guid);
		postData.put("guid", qkZd_guid);
				
		int code = baseService.doCallSp(postData, paramNames, null);
		
        return mv;
    }
	
