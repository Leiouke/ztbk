@Controller
@RequestMapping("/bk/sd")
public class qkZdController extends ZtbkServiceController{
	
	// 订单表头查询
	private int qkZdManageQueryId = 10000005;	
	private GridHeadConfig qkZdManageQueryHeadConfig;
		
	// 订单明细临时表查询
	private int qkZdItemManageQueryId = 10000006;	
	private GridHeadConfig qkZdItemManageQueryHeadConfig;
	
	// 订单刊期明细表
	private int qkZdItemPeriodManageQueryId = 10000007;	
	private GridHeadConfig qkZdItemPeriodManageQueryHeadConfig;
	
	// 商品信息查询
	private int productManageQueryId = 10000001;	
	private int productManageNoStopPublicationQueryId = 10000059;   //不包含停刊商品
	private GridHeadConfig productManageQueryHeadConfig;
	private GridHeadConfig productManageNoStopPublicationQueryHeadConfig;
	
	//单期明细查询
	private int productSingleItemQueryId = 10000015;
	private GridHeadConfig productSingleItemQueryHeadConfig;
	
	public qkZdController() {
		qkZdManageQueryHeadConfig = new GridHeadConfig(qkZdManageQueryId,true,false,true,false);
		qkZdManageQueryHeadConfig.setOperatorWidth(120);
		
		qkZdItemManageQueryHeadConfig = new GridHeadConfig(qkZdItemManageQueryId,true,true,true,false);
		qkZdItemManageQueryHeadConfig.setOperatorWidth(100);
		
		qkZdItemPeriodManageQueryHeadConfig = new GridHeadConfig(qkZdItemPeriodManageQueryId,true,false,true,false);
		qkZdItemPeriodManageQueryHeadConfig.setOperatorWidth(100);
		
		productManageQueryHeadConfig = new GridHeadConfig(productManageQueryId,true,true,false,false);
		productManageNoStopPublicationQueryHeadConfig = new GridHeadConfig(productManageNoStopPublicationQueryId,true,true,false,false);
		
		productSingleItemQueryHeadConfig = new GridHeadConfig(productSingleItemQueryId,true,true,false,false);
		
	}
	
	/**
	 * 进入报刊收订界面
	 * 
	 * @return
	 * @throws JsonProcessingException 
	 */
	@RequestMapping(value="/qkZdManage")  // 这里不写method, 说明既可以post也可以get
    public ModelAndView qkZdManage(HttpSession httpSession) throws JsonProcessingException{
        ModelAndView mv = new ModelAndView();
        mv.setViewName("sd/qkZd/qkZdManage");
        String tableHeader = this.getTableHeader(httpSession,qkZdManageQueryHeadConfig);
        mv.addObject("tableHeader", tableHeader);
		mv.addObject("queryId", qkZdManageQueryId);
        return mv;
    }
	
	/**
	 * 获得报刊收订数据
	 * 
	 * @return
	 */
	@RequestMapping(value="/getQkZdList")
	@ResponseBody
	public Object getQkZdList(@RequestBody Map postData, HttpSession httpSession) {
		return this.getTableDataList(postData, qkZdManageQueryId);
	}
	
	/**
	 * 删除报刊收订单
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteQkZd")
	@ResponseBody
    public Object deleteQkZd(@RequestParam Map postData,HttpSession httpSession){
		
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"zd_id", "o_id_destroy"};
		// 加入sp的名称
		postData.put("spName", "n_bk_qk_zd_delete");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_destroy", user.getAccount());
				
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
	 * 提交报刊收订单
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/verifyQkZd")
	@ResponseBody
    public Object verifyQkZd(@RequestParam Map postData,HttpSession httpSession){
		
		// 入参, 注意按照顺序
		String paramNames[] = new String[]{"zd_id", "is_verify","o_id_verify"};
		// 加入sp的名称
		postData.put("spName", "n_bk_qk_zd_verify");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_verify", user.getAccount());
		postData.put("is_verify", 1);
				
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
	/**
