		return this.getTableDataList(postData, qkZdItemManageQueryId);
	}
	
	/**
	 * 删除明细
	 * 
	 * 
	 */
	@RequestMapping(value="/deleteQkZdItemTempList")
	@ResponseBody
    public Object deleteQkZdItemTempList(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request)throws JsonProcessingException{
		
		String[] inc_nos = request.getParameterValues("inc_nos");
		if(inc_nos != null && inc_nos.length > 0){
			for(int i=0;i<inc_nos.length;i++){
		        String qkZd_guid = (String)httpSession.getAttribute("qkZd_guid");
				postData.put("guid", qkZd_guid);
				
				// 入参, 注意按照顺序
				String paramNames[] = {"guid","inc_no"};
				// 加入sp的名称
				postData.put("spName", "n_bk_qk_zd_item_temp_delete");
				
				postData.put("inc_no", inc_nos[i]);
				
				System.out.println("inc="+inc_nos[i]);
				
				int code = baseService.doCallSp(postData, paramNames, null);
				
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}

		return "{\"success\":true}";
    }
	
	/**
	 * 新增订单
	 * 
	 * @throws JsonProcessingException 
	 * 
	 * 
	 */
	@RequestMapping(value="/addQkZd")
	@ResponseBody
    public Object addQkZd(@RequestParam Map postData,HttpSession httpSession){
		
		User user=(User)httpSession.getAttribute("user");
		
		postData.put("o_id_create", user.getAccount());
		
		String qkZd_guid = (String)httpSession.getAttribute("qkZd_guid");
		postData.put("guid", qkZd_guid);
		
		String returnNames[] = {"zd_id"};
		
		// 入参, 注意按照顺序
		String paramNames[] = {
				  "guid",
		          "station_id",
		          "d_id",
		          "c_id",
		          "request_date",
		          "total_count",
		          "total_amount",
		          "total_money",
		          "input_date",
		          "o_id_input",
		          "o_id_operator",
		          "is_verify",
		          "o_id_verify",
		          "verify_date",
		          "is_destroy",
		          "destroy_date",
		          "o_id_destroy",
		          "receipts_class",
		          "create_date",
		          "o_id_create",
		          "collect_id",
		          "hurry_degree_id",
		          "sale_style_id",
		          "zd_info_source",
		          "memo",
		          "last_mod_date",
		          "last_trans_date",
		          "notrigger",
		          "station_id_aim",
		          "mark_id",
		          "reminder_signs",
		          "kind_id",
		          "is_mail",
		          "qk_zd_fee",
		          "real_money",
		          "is_transfer",
		          "js_attribute",
		          "zd_attribute",
		          "collect_style"
		          };
		
		postData.put("spName", "n_bk_qk_zd_new");
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		return "{\"success\":true}";
    }
	
