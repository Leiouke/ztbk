	@RequestMapping(value="/getQkZdItemTempList")
	@ResponseBody
	public Object getQkZdItemTempList(@RequestBody Map postData, HttpSession httpSession) {
		String qkZd_guid = (String)httpSession.getAttribute("qkZd_guid");
