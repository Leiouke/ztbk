 	/**
	 * 新增模版表头
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/addExcelTransferModel")
	@ResponseBody
    public Object addExcelTransferModel(@RequestParam Map postData,HttpSession httpSession) {	
		
		// 入参, 注意按照顺序
		String paramNames[] = {"template_name","start_line","sheet_no","input_code"};
		// 加入sp的名称
		postData.put("spName", "u_it_excel_template_new");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("input_code", user.getAccount());
		
		int code = baseService.doCallSp(postData, paramNames, null);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}

		return "{\"success\":true}";
    }
	
