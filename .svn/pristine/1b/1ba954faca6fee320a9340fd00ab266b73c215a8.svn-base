<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core"%>
<%
	String context = request.getContextPath();
	request.setAttribute("context",context);
%>
<!DOCTYPE html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8">
	    <meta http-equiv="X-UA-Compatible" content="IE=edge">
	    <meta name="viewport" content="width=device-width, initial-scale=1">
	    <!-- 上述3个meta标签*必须*放在最前面，任何其他内容都*必须*跟随其后！ -->
	    <!-- Bootstrap table -->
	    <link href="${context}/css/plugins/bootstrap-table/bootstrap-table.min.css" rel="stylesheet">
	    <link href="${context}/css/boocup_style.css" rel="stylesheet">
	    <link href="${context}/css/plugins/bootstrap-table/bootstrap-editable.css" rel="stylesheet">
	    <jsp:include page="../../include/h_superHead.jsp"></jsp:include>
	</head>
	<body>
	<div class="wrapper wrapper-content animated fadeInRight" style="padding-top:0px;padding-bottom:0px">
        <div class="ibox float-e-margins">
            <!-- <div class="ibox-title">
                <h5>打包发货</h5>
                <div class="ibox-tools">
                    <a class="collapse-link">
                        <i class="fa fa-chevron-up"></i>
                    </a>
                </div>
            </div> -->
            <div class="ibox-content" style="padding-bottom:0px">
                <div class="row row-lg">                    
                    <div class="col-sm-3">
                                <div class="btn-group hidden-xs" id="tableTool_qkDeatil" role="group">                                    
                                    <button type="button" class="btn btn-outline btn-default" id="config_qkDeatil">
                                        <i class="glyphicon glyphicon-cog" aria-hidden="true"></i>
                                    </button>
                                    <select class="form-control" >
                                   		<option value="all">导出全部</option>
						                <option value="basic">导出当页</option>	
						            </select>
                                </div>
                                <table id="table_qkDeatil" data-mobile-responsive="true">
                                    
                                </table>
                    </div>
                    <div class="col-sm-9">
                                <div class="btn-group hidden-xs" id="tableTool_hxDeatil" role="group">
                                    <button type="button" class="btn btn-outline btn-default" id="config_hxDeatil">
                                        <i class="glyphicon glyphicon-cog" aria-hidden="true"></i>
                                    </button>                                    
                                   <select class="form-control" >
                                   		<option value="all">导出全部</option>
						                <option value="basic">导出当页</option>	
						            </select>
                                </div>
                                <table id="table_hxDeatil" data-mobile-responsive="true">
                                    
                                </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="sonpage-footer">
    		 <button id="commit" class="btn btn-success" type="button">核销</button>
             <button id="cancel" class="btn btn-white" type="button">返回</button>
	</div>
	</body>
	<!-- 自定义js -->
    <script src="${context}/js/content.js?v=1.0.0"></script>


    <!-- Bootstrap table -->
    <script src="${context}/js/plugins/bootstrap-table/bootstrap-table.min.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/locale/bootstrap-table-zh-CN.min.js"></script>
    <!-- Bootstrap table editable-->
    <script src="${context}/js/plugins/bootstrap-table/bootstrap-editable.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/bootstrap-table-editable.js"></script>
    <!-- Bootstrap table export-->
    <script src="${context}/js/plugins/bootstrap-table/export/bootstrap-table-export.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/tableExport.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/js-xlsx/xlsx.core.min.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/jsPDF/jspdf.min.js"></script>
    <script src="${context}/js/plugins/bootstrap-table/export/jsPDF/jspdf.plugin.autotable.js"></script>
    <!-- Layer-->
    <script src="${context}/js/plugins/layer/layer.min.js"></script>
	<!-- plugins -->
 	<script src="${context}/js/plugins/suggest/bootstrap-suggest-new.min.js"></script>
	<!-- layerDate plugin javascript -->
    <script src="${context}/js/plugins/layer/laydate/laydate.js"></script>
    
	<script type="text/javascript">
		//inistal_data('#sd_date_start','#sd_date_end');
		//inistal_data('#last_sent_date_start','#last_sent_date_end');
		var invoice_str='${oneJson}';
	    invoice_str=invoice_str.replace(/\r\n/g,"\\r\\n")  
 	    invoice_str=invoice_str.replace(/\n/g,"\\n");
	    invoice_str=invoice_str.replace(/\s/g," ");
	    var invoice=JSON.parse(invoice_str);
	 
		var $table_qkDeatil = $('#table_qkDeatil');
		var $table_hxDeatil = $('#table_hxDeatil');
		
		function queryParams_qkDeatil(param) {
			var json_obj=formToJson($("#form_search"));
			json_obj['limit'] =param.limit;
   	      	json_obj['offset'] =param.offset;
   	     	json_obj['sortName'] =this.sortName;
   	  		json_obj['sortOrder'] =this.sortOrder;
   	  	    json_obj['inv_id'] =invoice.inv_id;
   	        return json_obj;
		}
		function queryParams_hxDeatil(param) {
			var json_obj=formToJson($("#form_search"));
			json_obj['limit'] =param.limit;
   	      	json_obj['offset'] =param.offset;
   	     	json_obj['sortName'] =this.sortName;
   	  		json_obj['sortOrder'] =this.sortOrder;
   	  	    json_obj['inv_id'] =invoice.inv_id;
   	        return json_obj;
		}
		
		$(document).ready(function () {
			//inistal_data('#sd_date_start','#sd_date_end');
			//加载字典数据
			get_dictionary("${context}",null);
			//bootstrap初始化
			initialize_table_no_footer($table_qkDeatil,"getInvoiceEditItemList",${tableHeader_qkDeatil},queryParams_qkDeatil,"#tableTool_qkDeatil",500);
			initialize_table_no_footer($table_hxDeatil,"getInvoiceVerifyItemList",${tableHeader_hxDeatil},queryParams_hxDeatil,"#tableTool_hxDeatil",450);
			
			//表格配置 layer
			var $config_qkDeatil=$("#config_qkDeatil");			
			table_column_config_layer($config_qkDeatil,2,'表格属性配置','${context}/csu/columnConfig?queryId=${queryId_qkDeatil}');
			var $config_hxDeatil=$("#config_hxDeatil");			
			table_column_config_layer($config_hxDeatil,2,'表格属性配置','${context}/csu/columnConfig?queryId=${queryId_hxDeatil}');
			
			$('#tableTool_qkDeatil').find('select').change(function () {				 
				 $table_qkDeatil.bootstrapTable('refreshOptions',{exportDataType: $(this).val()});
		     });
			 $('#tableTool_hxDeatil').find('select').change(function () {				 
				 $table_hxDeatil.bootstrapTable('refreshOptions',{exportDataType: $(this).val()});
		     });
			 initialize_bsSuggest_client("${context}");
			 
			 $('#commit').on('click', function () {
					ajax_function_ask_and_dosuccess("确认核销完成？","verifyInvoice","post",{inv_id:invoice.inv_id},verifySuccess)
			 });
			
	     });

		 function end_function(index, layero){ 
			 $table_offShelves.bootstrapTable('refresh');
			 $table_receivePerson.bootstrapTable('refresh');
	     }
		 
		 function verifySuccess(data) {
				if (data.success){
					layer.msg("核销完成");			
	        	} else {
	        		alert(data.errorMsg);
	        	}
	        }
	</script>
</html>