	/**
	 * 新增进货批次操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/addDhBatch")
	@ResponseBody
    public Object addDhBatch(@RequestParam Map postData,HttpSession httpSession,@RequestParam("customs_declaration_pdf")MultipartFile file,@RequestParam("tax_bill_pdf")MultipartFile file2) throws EncryptedDocumentException, InvalidFormatException, IOException {	
		if(file.getSize()!=0){
			postData.put("customs_declaration_pdf",file.getOriginalFilename());
			if (file != null) {
				// 首先获得图片存放的根路径
				Properties props = initialBeanListener.getProps();
				String imagePath = (String) props.get("images.rootPath");
				System.out.println(imagePath);
				// 目前以原文件名的方式上传, 后续在看看有无改进需要
				String fileName = file.getOriginalFilename();
				// 将上传的文件放到本地路径下
				FileUtils.copyInputStreamToFile(file.getInputStream(), new File(imagePath + "/dhbatchfile/" + fileName));
			}	
		}else{
			postData.put("customs_declaration_pdf","");
		}
		
		if(file2.getSize()!=0){
			postData.put("tax_bill_pdf",file2.getOriginalFilename());
			if (file2 != null) {
				// 首先获得图片存放的根路径
				Properties props = initialBeanListener.getProps();
				String imagePath = (String) props.get("images.rootPath");
				System.out.println(imagePath);
				// 目前以原文件名的方式上传, 后续在看看有无改进需要
				String fileName = file2.getOriginalFilename();
				// 将上传的文件放到本地路径下
				FileUtils.copyInputStreamToFile(file2.getInputStream(), new File(imagePath + "/dhbatchfile/" + fileName));
			}
		}else{
			postData.put("tax_bill_pdf","");
		}
		
		// 入参, 注意按照顺序
		String paramNames[] = dhBatchUtil.getParamNames_batch_new();
		// 出参, 有顺序
		String returnNames[] = dhBatchUtil.getParamNames_batch_new_out();
		// 加入sp的名称
		postData.put("spName", dhBatchUtil.getSpName_batch_new());
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("created_by", user.getAccount());
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		return "{\"success\":true}";
    }
	
