   	/**
	 * 引入发票明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/pullDhBatchItem")
	@ResponseBody
    public Object pullDhBatchItem(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession,HttpServletRequest request){
		String batch_id=(String)httpSession.getAttribute("batch_id");
		User user=(User)httpSession.getAttribute("user");
		if(postData!=null&&postData.size()>0){
			for(Map<String,Object> inv_map:postData){				
				// 入参, 注意按照顺序
				String paramNames[] = new String[]{"batch_id", "invoice_id", "operator"};
				// 加入sp的名称
				inv_map.put("spName", "bk_qk_dh_batch_invoice_new");				
				inv_map.put("batch_id", batch_id);		
				inv_map.put("operator", user.getAccount());
				int code = baseService.doCallSp(inv_map, paramNames, null);					
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}		
		return "{\"success\":true}";
    }
	
	/**
	 * 删除明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteDhBatchItem")
	@ResponseBody
    public Object deleteSaleInvoiceItem(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request){	
		String batch_id=(String)httpSession.getAttribute("batch_id");
		User user=(User)httpSession.getAttribute("user");
		
		String[] inv_ids=request.getParameterValues("inv_ids");
		if(inv_ids!=null && inv_ids.length>0){
			for(int i=0;i<inv_ids.length;i++){
				// 入参, 注意按照顺序
				String paramNames[] = new String[]{"batch_id", "invoice_id", "operator"};
				// 加入sp的名称
				postData.put("spName", "bk_qk_dh_batch_invoice_delete");					
				postData.put("batch_id", batch_id);
				postData.put("invoice_id", inv_ids[i]);
				postData.put("operator", user.getAccount());

				int code = baseService.doCallSp(postData, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}	
		
		return "{\"success\":true}";
    }
   	
