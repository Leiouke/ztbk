	//下载浏览器文件
	@RequestMapping(value="/getFileDownLoad")
	public void getFileDownLoad(HttpServletResponse response,HttpServletRequest request) throws EncryptedDocumentException, InvalidFormatException, IOException {
		// 首先获得图片存放的根路径
		Properties props = initialBeanListener.getProps();
		String imagePath = (String) props.get("images.rootPath");
			
		String filename=request.getParameter("attached_file_memo");

		ByteArrayOutputStream out = new ByteArrayOutputStream();  
						
		FileInputStream fis = new FileInputStream(imagePath + "/dhbatchfile/" + filename);
						
		byte[] buffer = new byte[1024];
		int len;
		while ((len = fis.read(buffer)) != -1 ) {  
			out.write(buffer, 0, len);  
		}
		out.flush();

		byte[] bytes = out.toByteArray();
		response.setContentType("application/x-msdownload");    
		response.setContentLength(bytes.length);  
		response.setHeader("Content-Disposition", "attachment;filename="  
			         + new String(filename.getBytes("gb2312"), "ISO8859-1"));
		response.getOutputStream().write(bytes); 
	}
	
