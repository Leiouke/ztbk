		String paramNames[] = {"id"};
		// 加入sp的名称
		postData.put("spName", "u_basic_bank_delete");
		int code = baseService.doCallSp(postData, paramNames, null);		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		return "{\"success\":true}";
