package com.cnpiecsb.system.entity;

public class Role {
	private int id;
	
	private String name;
	
	private int roleId;  // 这个是菜单角色的id
	
	private int approve_role;  // 这个是审批角色,字典内容, 经理啊 普通员工的
	
	private int defaultSubsystem;  // 默认子系统
	
	private String subsystemName;  // 默认子系统名称
	
	private String dep_org_name;
	
	private String dep_org_code;
	
	private String office_org_name;
	
	private String office_org_code;
	
	private String group_org_name;
	
	private String group_org_code;
	
	private String org_name;  // 带完整组织机构的名称
	
	private String org_code;
	
	private boolean is_default;

	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public int getRoleId() {
		return roleId;
	}

	public void setRoleId(int roleId) {
		this.roleId = roleId;
	}

	public int getDefaultSubsystem() {
		return defaultSubsystem;
	}

	public void setDefaultSubsystem(int defaultSubsystem) {
		this.defaultSubsystem = defaultSubsystem;
	}

	public String getSubsystemName() {
		return subsystemName;
	}

	public void setSubsystemName(String subsystemName) {
		this.subsystemName = subsystemName;
	}

	public String getDep_org_name() {
		return dep_org_name;
	}

	public void setDep_org_name(String dep_org_name) {
		this.dep_org_name = dep_org_name;
	}

	public String getDep_org_code() {
		return dep_org_code;
	}

	public void setDep_org_code(String dep_org_code) {
		this.dep_org_code = dep_org_code;
	}

	public String getOffice_org_name() {
		return office_org_name;
	}

	public void setOffice_org_name(String office_org_name) {
		this.office_org_name = office_org_name;
	}

	public String getOffice_org_code() {
		return office_org_code;
	}

	public void setOffice_org_code(String office_org_code) {
		this.office_org_code = office_org_code;
	}

	public String getGroup_org_name() {
		return group_org_name;
	}

	public void setGroup_org_name(String group_org_name) {
		this.group_org_name = group_org_name;
	}

	public String getGroup_org_code() {
		return group_org_code;
	}

	public void setGroup_org_code(String group_org_code) {
		this.group_org_code = group_org_code;
	}

	public String getOrg_name() {
		return org_name;
	}

	public void setOrg_name(String org_name) {
		this.org_name = org_name;
	}

	public String getOrg_code() {
		return org_code;
	}

	public void setOrg_code(String org_code) {
		this.org_code = org_code;
	}

	public boolean isIs_default() {
		return is_default;
	}

	public void setIs_default(boolean is_default) {
		this.is_default = is_default;
	}

	public int getApprove_role() {
		return approve_role;
	}

	public void setApprove_role(int approve_role) {
		this.approve_role = approve_role;
	}
}
