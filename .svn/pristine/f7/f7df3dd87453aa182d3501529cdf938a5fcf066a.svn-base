package com.cnpiecsb.csu.entity.viewobject;
/**
 * grid表头配置
 * 
 * @author user
 *
 */
public class GridHeadConfig {
	// 查询号
	private int queryId;
	
	// 是否增加行号列
	private boolean lineNo;
	
	// 是否增加复选框列
	private boolean checkbox;
	
	// 是否增加操作列
	private boolean operator;
	
	// 操作列是否在最右边, 默认是
	private boolean operatorRight = true;
	
	// 复选框列宽度, 默认36 
	private int checkboxWidth = 36;

	// 操作列宽度, 默认50 
	private int operatorWidth = 50;
	
	// 行号列宽度, 默认44 
	private int lineNoWidth = 44;
	
	public GridHeadConfig(int queryId){
		this.queryId = queryId;
	}
	
	public GridHeadConfig(int queryId, boolean lineNo, boolean checkbox, boolean operator, boolean operatorRight){
		this.queryId = queryId;
		this.lineNo = lineNo;
		this.checkbox = checkbox;
		this.operator = operator;
		this.operatorRight = operatorRight;
	}

	public boolean isLineNo() {
		return lineNo;
	}

	public void setLineNo(boolean lineNo) {
		this.lineNo = lineNo;
	}

	public boolean isCheckbox() {
		return checkbox;
	}

	public void setCheckbox(boolean checkbox) {
		this.checkbox = checkbox;
	}

	public boolean isOperator() {
		return operator;
	}

	public void setOperator(boolean operator) {
		this.operator = operator;
	}

	public boolean isOperatorRight() {
		return operatorRight;
	}

	public void setOperatorRight(boolean operatorRight) {
		this.operatorRight = operatorRight;
	}

	public int getQueryId() {
		return queryId;
	}

	public void setQueryId(int queryId) {
		this.queryId = queryId;
	}
	
	public int getOperatorWidth() {
		return operatorWidth;
	}

	public void setOperatorWidth(int operatorWidth) {
		this.operatorWidth = operatorWidth;
	}

	public int getCheckboxWidth() {
		return checkboxWidth;
	}

	public void setCheckboxWidth(int checkboxWidth) {
		this.checkboxWidth = checkboxWidth;
	}

	public int getLineNoWidth() {
		return lineNoWidth;
	}

	public void setLineNoWidth(int lineNoWidth) {
		this.lineNoWidth = lineNoWidth;
	}
	
}
