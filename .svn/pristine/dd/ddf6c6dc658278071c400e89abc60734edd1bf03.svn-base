	/**
	 * 删除操作 申汇单
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteFinanceFhsh")
	@ResponseBody
    public Object deleteFinanceFhsh(@RequestParam Map postData,HttpSession httpSession){
		// 入参, 注意按照顺序
		String paramNames[] = {"fh_id","o_id_destroy"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_delete");
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_destroy", user.getAccount());
        
		int code = baseService.doCallSp(postData, paramNames, null);		
		if (code != 0) {
			return this.getAjaxResult(code);
		}		
		postData.remove("paramNames");
		code=do_sp_invoice_sw_calculate(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}		
		return "{\"success\":true}";
    }
	
	/**
	 * 提交申汇审核操作(含保存)
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/commitFinanceFhsh")
	@ResponseBody
    public Object commitFinanceFhsh(@RequestParam Map postData,HttpSession httpSession){	
		String finance_fhsh_guid=(String)httpSession.getAttribute("finance_fhsh_guid");
		postData.put("guid", finance_fhsh_guid);
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_input", user.getAccount());
		
		int code = do_sp_finance_fhsh_update(postData);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}		
		postData.remove("paramNames");
		code=do_sp_invoice_sw_calculate(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		postData.remove("paramNames");
		code=do_sp_finance_fhsh_commit(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		//执行接口推送
		postData.put("bill_code", postData.get("fh_id"));
						
		int result_code = oaApiDeal(postData,user.getAccount());
						
		if(result_code ==1){
			AjaxResult result = new AjaxResult();
			result.setSuccess(false);
			result.setErrorMsg("接口报错");
			return result;
		}

		return "{\"success\":true}";
    }
	
	/**
	 * 提交申汇审核操作(不含保存)
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/onlyCommitFinanceFhsh")
	@ResponseBody
    public Object onlyCommitFinanceFhsh(@RequestParam Map postData,HttpSession httpSession){	
		int code = do_sp_finance_fhsh_commit(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		// 生成 财务进货分类汇总
		postData.remove("paramNames");
		code=do_sp_finance_purchase_item_classfy(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		//执行接口推送
		User user=(User)httpSession.getAttribute("user");
		postData.put("bill_code", postData.get("fh_id"));
				
		int result_code = oaApiDeal(postData,user.getAccount());
				
		if(result_code ==1){
			AjaxResult result = new AjaxResult();
			result.setSuccess(false);
			result.setErrorMsg("接口报错");
			return result;
		}

		return "{\"success\":true}";
    }
	
	//提交审核申汇
	private int do_sp_finance_fhsh_commit(Map postData){
		String paramNames[] = {"fh_id","guid"};
		// 加入sp的名称
