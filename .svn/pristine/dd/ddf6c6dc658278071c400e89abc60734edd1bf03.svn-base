   	/**
	 * 引入明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/pullFinanceFhshItem")
	@ResponseBody
    public Object pullFinanceFhshItem(@RequestBody List<Map<String,Object>> postData,HttpSession httpSession,HttpServletRequest request){
		String finance_fhsh_guid=(String)httpSession.getAttribute("finance_fhsh_guid");
		if(postData!=null&&postData.size()>0){
			for(Map<String,Object> inv_map:postData){
				// 入参, 注意按照顺序
				String paramNames[] = {"guid","inv_id","fh_money"};
				// 加入sp的名称
				inv_map.put("spName", "u_finance_fhsh_item_pullin");
				
				inv_map.put("guid", finance_fhsh_guid);
				
				int code = baseService.doCallSp(inv_map, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}			
		
		return "{\"success\":true}";
    }
	
	/**
	 * 删除明细操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/deleteFinanceFhshItem")
	@ResponseBody
	@OperationLogAnnotation(context="删除申汇明细")
    public Object deleteFinanceFhshItem(@RequestParam Map postData,HttpSession httpSession,HttpServletRequest request) {	
		String finance_fhsh_guid=(String)httpSession.getAttribute("finance_fhsh_guid");
		postData.put("guid", finance_fhsh_guid);
		
		String[] inv_ids=request.getParameterValues("inv_ids");
		if(inv_ids!=null&&inv_ids.length>0){
			for(int i=0;i<inv_ids.length;i++){
				// 入参, 注意按照顺序
				String paramNames[] = {"guid","inv_id"};
				// 加入sp的名称
				postData.put("spName", "u_finance_fhsh_item_delete");					
				
				postData.put("inv_id", inv_ids[i]);

				int code = baseService.doCallSp(postData, paramNames, null);
						
				if (code != 0) {
					return this.getAjaxResult(code);
				}
			}
		}	
		
		return "{\"success\":true}";
    }
	
	/**
	 * 新增申汇操作
	 * 
	 * param postData
	 * return
	 */
	@RequestMapping(value="/addFinanceFhsh")
	@ResponseBody
    public Object addFinanceFhsh(@RequestParam Map postData,HttpSession httpSession){
		
		// 入参, 注意按照顺序
		String paramNames[] = {"guid","f_id","o_id_operator","o_id_input","fh_date","currency","fh_money","invoice_amount",
				"total_money","region_catagory","bank_id","is_advance","is_bail","memo","fw_mode","fhsh_family","c_id"};
		// 出参, 有顺序
		String returnNames[] = {"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_fhsh_new");
		
		String finance_fhsh_guid=(String)httpSession.getAttribute("finance_fhsh_guid");
		postData.put("guid", finance_fhsh_guid);
		
		User user=(User)httpSession.getAttribute("user");
		postData.put("o_id_input", user.getAccount());
		
		int code = baseService.doCallSp(postData, paramNames, returnNames);
		
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		postData.remove("paramNames");
		code = do_sp_invoice_sw_calculate(postData);				
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		postData.remove("paramNames");
		code=do_sp_finance_item_classfy(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		postData.remove("paramNames");
		code=do_sp_finance_purchase_item_classfy(postData);
		if (code != 0) {
			return this.getAjaxResult(code);
		}
		
		// 以下获得出参值
		return "{\"success\":true}";
    }
	
	//计算发票已申汇金额
	private int do_sp_invoice_sw_calculate(Map postData){
		String paramNames[] = {"fh_id"};
		// 加入sp的名称
		postData.put("spName", "u_finance_invoice_sw_calculate");
		return  baseService.doCallSp(postData, paramNames, null);
	}
	
