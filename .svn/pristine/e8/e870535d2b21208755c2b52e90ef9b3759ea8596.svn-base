		function initLaydate() {
    // 开始日期控件
    laydate.render({
        elem: '#period_start',
        format: 'yyyy-MM-dd',
        max: '2099-06-16',
        btns: ['clear', 'confirm'],
        done: function(value, date) {
            // 每次选择时，动态获取当前模式
            var qk_attribute = $('#qk_attribute').val();
            
            if (qk_attribute == "01") {
                // 报纸模式：调整为周一
                var selectedDate = new Date(value);
                var weekDay = selectedDate.getDay();
                
                if (weekDay !== 1) {
                    var offset = weekDay === 0 ? -6 : -(weekDay - 1);
                    selectedDate.setDate(selectedDate.getDate() + offset);
                    var adjustedValue = formatDate(selectedDate);
                    $('#period_start').val(adjustedValue);
                    layer.msg('报纸开始时间为周一,已自动调整为周一：' + adjustedValue);
                    value = adjustedValue;
                }
            } else {
                // 普通模式：调整为当月1号
                var selectedDate = new Date(value);
                var day = selectedDate.getDate();
                
                if (day !== 1) {
                    selectedDate.setDate(1);
                    var adjustedValue = formatDate(selectedDate);
                    $('#period_start').val(adjustedValue);
                    layer.msg('已自动调整为当月1号：' + adjustedValue);
                    value = adjustedValue;
                }
            }
            
            // 如果结束日期小于开始日期，清空结束日期
            var endVal = $('#period_end').val();
            if (endVal && endVal < value) {
                $('#period_end').val('');
                layer.msg('结束日期不能早于开始日期，已清空', {icon: 2});
            }
        }
    });
    
    // 结束日期控件
    laydate.render({
        elem: '#period_end',
        format: 'yyyy-MM-dd',
        max: '2099-06-16',
        btns: ['clear', 'confirm'],
        ready: function() {
            // 面板打开时，禁用开始日期之前的日期
            setTimeout(function() {
                disableDatesBeforeStart();
            }, 10);
        },
        change: function() {
            // 切换月份时，重新禁用开始日期之前的日期
            setTimeout(function() {
                disableDatesBeforeStart();
            }, 10);
        },
        done: function(value, date) {
            var qk_attribute = $('#qk_attribute').val();
            var startVal = $('#period_start').val();
            
            // 验证结束日期不能小于开始日期
            if (startVal && value < startVal) {
                layer.msg('结束日期不能早于开始日期！', {icon: 2});
                $('#period_end').val('');
                return false;
            }
            
            if (qk_attribute == "01") {
                // 报纸模式：调整为周日
                var selectedDate = new Date(value);
                var weekDay = selectedDate.getDay();
                
                if (weekDay !== 0) {
                    var offset = weekDay === 0 ? 0 : 7 - weekDay;
                    selectedDate.setDate(selectedDate.getDate() + offset);
                    var adjustedValue = formatDate(selectedDate);
                    $('#period_end').val(adjustedValue);
                    layer.msg('报纸结束时间为周日,已自动调整为周日：' + adjustedValue);
                }
            } else {
                // 普通模式：调整为当月最后一天
                var selectedDate = new Date(value);
                var year = selectedDate.getFullYear();
                var month = selectedDate.getMonth();
                var lastDay = new Date(year, month + 1, 0).getDate();
                var selectedDay = selectedDate.getDate();
                
                if (selectedDay !== lastDay) {
                    selectedDate.setDate(lastDay);
                    var adjustedValue = formatDate(selectedDate);
                    $('#period_end').val(adjustedValue);
                    layer.msg('已自动调整为当月最后一天：' + adjustedValue);
                }
            }
        }
    });
}

// 禁用开始日期之前的日期
function disableDatesBeforeStart() {
    var startVal = $('#period_start').val();
    if (!startVal) return;
    
    var startDate = new Date(startVal);
    startDate.setHours(0, 0, 0, 0);
    
    // 查找所有日期单元格
    var $tds = $('.layui-laydate-table td');
    
    $tds.each(function() {
        var $td = $(this);
        // 获取单元格中的日期数字
        var dayText = $td.find('.layui-laydate-day').text().trim();
        if (!dayText || isNaN(parseInt(dayText))) return;
        
        // 获取当前单元格的完整日期
        var year = parseInt($('.layui-laydate-year').text());
        var month = parseInt($('.layui-laydate-month').text());
        var day = parseInt(dayText);
        
        // 判断是否是当前月份的日期
        var isCurrentMonth = !$td.hasClass('laydate-day-prev') && !$td.hasClass('laydate-day-next');
        
        if (isCurrentMonth) {
            var cellDate = new Date(year, month - 1, day);
            cellDate.setHours(0, 0, 0, 0);
            
            // 如果单元格日期小于开始日期，则禁用
            if (cellDate < startDate) {
                $td.addClass('layui-laydate-disabled');
                $td.css({
                    'pointer-events': 'none',
                    'opacity': '0.5',
                    'background-color': '#f5f5f5'
                });
            } else {
                $td.removeClass('layui-laydate-disabled');
                $td.css({
                    'pointer-events': '',
                    'opacity': '',
                    'background-color': ''
                });
            }
        }
    });
}

// 辅助函数
function formatDate(date) {
    var y = date.getFullYear();
    var m = (date.getMonth() + 1).toString().padStart(2, '0');
    var d = date.getDate().toString().padStart(2, '0');
    return y + '-' + m + '-' + d;
}
 
	</script>
	
</html>