			   json_obj['mail_code'] =$('#mail_code').val();
		   }
		   if($('#qk_issn').val()!=null&&$('#qk_issn').val()!=""){
			   json_obj['qk_issn'] =$('#qk_issn').val();
		   }
		   if($('#qk_name').val()!=null&&$('#qk_name').val()!=""){
			   json_obj['qk_name'] =$('#qk_name').val();
		   }
   	        return json_obj;
		}
	    
